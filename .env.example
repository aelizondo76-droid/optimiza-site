# ── Motor del scanner (copia a .env y completa) ──────────────────────────
# Sin estas variables el sitio DESPLIEGA igual, pero en modo degradado:
# el escaneo corre, pero la velocidad real y el guardado del informe requieren claves.

# 1) Google PageSpeed Insights — velocidad real (Core Web Vitals). GRATIS 25k/día.
#    Consíguela en: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# 2) Upstash Redis — guarda informes + rate-limit + dedup. REQUERIDO en producción.
#    Crea una base gratis en https://upstash.com y copia las credenciales REST.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 3) Resend — envío del email con el informe. GRATIS 3k emails/mes.
#    https://resend.com — verifica el dominio optimizahq.com para enviar desde él.
RESEND_API_KEY=
SCAN_FROM_EMAIL=Optimiza <informes@optimizahq.com>
# Correo real donde recibir las RESPUESTAS de los leads (informes@ no tiene buzón).
SCAN_REPLY_TO=
# A dónde llegan los AVISOS de nuevos leads (scanner + formulario). Debe ser un
# buzón que reciba de verdad (ej. alonso@optimizahq.com). Si se omite, usa SCAN_REPLY_TO.
LEAD_NOTIFY_EMAIL=

# (Opcional) Habilita el admin de Keystatic en producción. Déjalo VACÍO: por
# seguridad, /keystatic queda bloqueado en producción salvo que definas esto.
ENABLE_KEYSTATIC=

# 4) URL pública del sitio (para los enlaces del email).
PUBLIC_SITE_URL=https://optimizahq.com

# 5) Panel de leads en /leads (protegido con Basic Auth). Define una contraseña.
LEADS_USER=optimiza
LEADS_PASSWORD=

# 6) Capa de medición del PROPIO sitio (pilar Automatización). Variables PUBLIC_*
#    → se inyectan en el build, así que requieren Redeploy al cambiarlas.
#    Activa solo las que vayas a usar de verdad.
PUBLIC_GA4_ID=              # Google Analytics 4, ej: G-XXXXXXXXXX
PUBLIC_META_PIXEL_ID=       # Meta Pixel, ej: 123456789012345
PUBLIC_CLARITY_ID=          # Microsoft Clarity (mapas de calor, gratis)
PUBLIC_TIKTOK_PIXEL_ID=     # TikTok Pixel (solo si pautas en TikTok)
PUBLIC_WHATSAPP_NUMBER=     # WhatsApp internacional sin '+', ej: 50688887777
PUBLIC_WHATSAPP_MSG=        # (opcional) mensaje prellenado del botón
