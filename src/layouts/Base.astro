---
import '@fontsource-variable/inter';
import '@fontsource/playfair-display/700.css';
import '@fontsource/playfair-display/800.css';
import '@fontsource/space-mono/400.css';
import '@fontsource/space-mono/700.css';
import interUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import playfairUrl from '@fontsource/playfair-display/files/playfair-display-latin-700-normal.woff2?url';
import spaceMonoUrl from '@fontsource/space-mono/files/space-mono-latin-400-normal.woff2?url';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Defs from '../components/Defs.astro';
import Analytics from '../components/Analytics.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

interface Props {
  title: string;
  description: string;
  active?: string;
  ogImage?: string | null;
  breadcrumbs?: { name: string; url: string }[];
}
const { title, description, active, ogImage, breadcrumbs } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : null;

// Entidad única, referenciada por su @id desde WebSite y desde los bloques
// Report/Dataset de /analisis — así el grafo no repite 33+ Organization sueltas.
const ORG_ID = 'https://optimizahq.com/#organization';
const org = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': ORG_ID,
  name: 'Optimiza',
  url: 'https://optimizahq.com',
  slogan: 'Optimizamos tu negocio a través de tu web',
  description: 'Firma de optimización web: velocidad, SEO, conversión y automatización, medido en ventas.',
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    url: 'https://optimizahq.com/contacto',
  },
};
const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Optimiza',
  url: 'https://optimizahq.com',
  publisher: { '@id': ORG_ID },
};
const defaultCrumbs = [{ name: 'Inicio', url: 'https://optimizahq.com/' }];
const crumbLd = breadcrumbs?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [...defaultCrumbs, ...breadcrumbs].map((c, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: c.name,
        item: c.url,
      })),
    }
  : null;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href={interUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={playfairUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={spaceMonoUrl} as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Optimiza" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    <meta name="generator" content={Astro.generator} />
    <script type="application/ld+json" set:html={JSON.stringify(org)} />
    <script type="application/ld+json" set:html={JSON.stringify(website)} />
    {crumbLd && <script type="application/ld+json" set:html={JSON.stringify(crumbLd)} />}
    <Analytics />
    <slot name="head" />
  </head>
  <body>
    <Defs />
    <Nav active={active} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
    <script>
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const nav = document.getElementById('nav');
      const onScroll = () => nav && nav.classList.toggle('scrolled', window.scrollY > 12);
      window.addEventListener('scroll', onScroll, { passive: true }); onScroll();
      if ('IntersectionObserver' in window && !reduce) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
        }, { threshold: 0.12 });
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
      }
      document.querySelectorAll('.qa .q').forEach((btn) => {
        btn.addEventListener('click', () => {
          const qa = btn.parentElement!;
          const a = qa.querySelector('.a') as HTMLElement;
          const open = qa.classList.toggle('open');
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          a.style.maxHeight = open ? a.scrollHeight + 'px' : '0';
        });
      });
    </script>
  </body>
</html>
