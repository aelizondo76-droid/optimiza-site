---
import Base from '../layouts/Base.astro';
import Scanner from '../components/Scanner.astro';
import { getSeo } from '../lib/seo';
const seo = await getSeo('home', {
  title: 'Optimiza — Optimización de negocios a través de tu web',
  description: 'No solo optimizamos tu web: optimizamos tu negocio a través de ella. Analiza tu sitio al instante y descubre dónde pierdes ventas — y cuánto puedes recuperar.',
});
const title = seo.title;
const description = seo.description;
---
<!-- Hallmark · macrostructure: Stat-Led (fused) · differs from default AI-SaaS flow on: proof folded into hero, método+pricing fused 2-col, FAQ+CTA fused -->
<Base title={title} description={description}>
  <section class="hero section hero-data dark">
    <div class="wrap">
      <div class="hero-statement">
        <div class="stat-card stat-primary reveal">
          <div class="stat-number">386</div>
          <div class="stat-label">Sitios analizados</div>
          <div class="stat-context">Costa Rica · 2026</div>
        </div>
        <div class="stat-card stat-warning reveal">
          <div class="stat-number">88<span class="pct">%</span></div>
          <div class="stat-label">Sin Meta Pixel</div>
          <div class="stat-context">Ciego total a sus clientes</div>
        </div>
        <div class="stat-card stat-critical reveal">
          <div class="stat-number">$122M</div>
          <div class="stat-label">Pérdida anual</div>
          <div class="stat-context">En oportunidades no recuperadas</div>
        </div>
      </div>

      <h1 class="hero-title reveal">Tu competidor que lo use en 3 meses, te vencerá en 6.</h1>

      <div class="before-after reveal">
        <div class="ba-item ba-before">
          <div class="ba-visual ba-broken">
            <svg viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg">
              <rect x="20" y="20" width="160" height="100" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="5,5" opacity="0.3"/>
              <circle cx="100" cy="70" r="25" fill="none" stroke="currentColor" stroke-width="2" opacity="0.3"/>
              <text x="100" y="85" text-anchor="middle" font-size="12" fill="currentColor" opacity="0.3">Invisible</text>
              <g opacity="0.2">
                <path d="M 60 40 L 80 50 L 100 35 L 120 55 L 140 45" stroke="currentColor" stroke-width="2" fill="none"/>
              </g>
            </svg>
          </div>
          <div class="ba-text">
            <div class="ba-title">Sin Optimizar</div>
            <div class="ba-metric">Índice: <strong>42/100</strong></div>
            <div class="ba-metric">Pixel: <strong>0%</strong></div>
            <div class="ba-metric">Conversión: <strong>0.8%</strong></div>
          </div>
        </div>

        <div class="ba-arrow">
          <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
            <path d="M 20 5 L 35 20 L 20 35" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <div class="ba-item ba-after">
          <div class="ba-visual ba-optimized">
            <svg viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg">
              <rect x="20" y="20" width="160" height="100" fill="none" stroke="currentColor" stroke-width="2"/>
              <circle cx="100" cy="70" r="25" fill="currentColor" opacity="0.8"/>
              <text x="100" y="75" text-anchor="middle" font-size="14" fill="white" font-weight="bold">✓</text>
              <g>
                <path d="M 60 40 L 80 50 L 100 35 L 120 55 L 140 45" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
              </g>
            </svg>
          </div>
          <div class="ba-text">
            <div class="ba-title">Con Optimiza</div>
            <div class="ba-metric">Índice: <strong>85/100</strong></div>
            <div class="ba-metric">Pixel: <strong>100%</strong></div>
            <div class="ba-metric">Conversión: <strong>2.0%</strong></div>
          </div>
        </div>
      </div>

      <div class="scanwrap reveal"><Scanner /></div>

      <p class="hero-sub reveal">Sin registro para ver tu puntaje. Los pilares que no mides son los que más te cuestan.</p>

      <div class="hero-cta-row reveal">
        <a class="btn btn-ghost" href="#metodo">Ver cómo trabajamos</a>
      </div>

      <div class="hero-proof reveal">
        <p class="pmsg">No lo prometemos, lo demostramos. <b>Este mismo sitio</b> corre con puntaje perfecto — el tuyo también puede.</p>
        <div class="readout">
          <div class="r"><div class="rn">100<small>/100</small></div><div class="rl">PageSpeed</div></div>
          <div class="r"><div class="rn">0.4<small>s</small></div><div class="rl">Carga</div></div>
          <div class="r"><div class="rn">A<small>+</small></div><div class="rl">Core Web Vitals</div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section statband reveal">
    <div class="wrap">
      <p class="big">Un sitio lento no es un detalle técnico. Es <em>dinero que se va</em> — hasta un 7% de tus ventas por cada segundo de más.</p>
      <p class="src">Fuente: datos de la industria sobre velocidad y conversión</p>
    </div>
  </section>

  <section class="section" id="pilares">
    <div class="wrap">
      <div class="shead reveal">
        <h2>Todo lo que tu web necesita para vender, en un solo lugar.</h2>
        <p class="lead">Cuatro palancas que trabajan juntas: atraer, cargar rápido, convertir y automatizar. No vendemos tareas técnicas — vendemos el resultado de negocio de cada una.</p>
      </div>
      <div class="pillars">
        <article class="pcard pcard-lead reveal">
          <div class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2l-8 14h6l-2 6 10-15h-6l2-5Z"/></svg></div>
          <div class="pcard-body">
            <h3>Velocidad</h3><p class="hook">&ldquo;Cada segundo cuesta ventas.&rdquo;</p>
            <p class="desc">Core Web Vitals, compresión de imágenes y código limpio para que tu web cargue al instante.</p>
          </div>
        </article>
        <div class="pillars-rest">
          <article class="pcard reveal">
            <div class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8Z"/><circle cx="12" cy="12" r="3"/></svg></div>
            <h3>Visibilidad</h3><p class="hook">&ldquo;Que te encuentren primero.&rdquo;</p>
            <p class="desc">SEO técnico, contenido y optimización para IA — para que aparezcas antes que tu competencia.</p>
          </article>
          <article class="pcard reveal">
            <div class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 20V6"/><path d="M3 6l4 4 4-6 6 8 4-2"/><path d="M20 6v2"/></svg></div>
            <h3>Conversión</h3><p class="hook">&ldquo;Convierte tráfico en clientes.&rdquo;</p>
            <p class="desc">Landing pages, medición y pruebas A/B para que las visitas que ya tienes se vuelvan ventas.</p>
          </article>
          <article class="pcard reveal">
            <div class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="12" r="3"/><circle cx="15" cy="12" r="3"/><path d="M9 9v6M15 9v6M12 12h0"/><path d="M6 12a3 3 0 0 0 6 0 3 3 0 0 1 6 0 3 3 0 0 0 0-6"/></svg></div>
            <h3>Automatización</h3><p class="hook">&ldquo;Que tu negocio trabaje sin ti.&rdquo;</p>
            <p class="desc">CRM, integraciones y flujos que convierten tu crecimiento en tiempo libre recuperado.</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="metodo">
    <div class="wrap">
      <div class="method-grid">
        <div class="method-col">
          <div class="shead reveal">
            <h2>Sin cajas negras.</h2>
            <p class="lead">Un proceso claro, en cuatro pasos, donde cada acción se justifica por su impacto en ventas — no por horas facturadas.</p>
          </div>
          <ol class="timeline reveal">
            <li><span class="step-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg></span><div><div class="sn">01 · Diagnosticamos</div><p>Auditoría técnica completa de velocidad, SEO y conversión.</p></div></li>
            <li><span class="step-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg></span><div><div class="sn">02 · Priorizamos</div><p>Ordenamos cada mejora por impacto en tus ventas, no por dificultad.</p></div></li>
            <li><span class="step-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"></path><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"></path><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"></path><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"></path></svg></span><div><div class="sn">03 · Ejecutamos</div><p>Implementamos rápido, con reportes claros en cada paso.</p></div></li>
            <li><span class="step-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="2" y2="22"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg></span><div><div class="sn">04 · Medimos</div><p>Reportamos resultados en la métrica que importa: dinero.</p></div></li>
          </ol>
        </div>

        <div class="method-col" id="paquetes">
          <div class="shead reveal">
            <h2>Empieza donde estás. Escala cuando estés listo.</h2>
            <p class="lead">Una escalera clara: entra por un diagnóstico gratis y sube de nivel solo cuando el anterior ya te esté generando resultados.</p>
          </div>
          <div class="ladder-v reveal">
            <article class="rung-v free"><div class="rv-top"><span class="lvl">Paso 0</span><span class="kind">Gratis</span></div><h3>Diagnóstico</h3><p class="for">Descubre qué te frena y cuánto puedes ganar.</p></article>
            <article class="rung-v"><div class="rv-top"><span class="lvl">Nivel 1</span><span class="kind">Proyecto</span></div><h3>Cimientos</h3><p class="for">Para que tu web deje de perder ventas: base técnica sólida.</p></article>
            <article class="rung-v"><div class="rv-top"><span class="lvl">Nivel 2</span><span class="kind">Retainer</span></div><h3>Aceleración</h3><p class="for">Para crecer ventas mes a mes: tráfico y conversión.</p></article>
            <article class="rung-v"><div class="rv-top"><span class="lvl">Nivel 3</span><span class="kind">Premium</span></div><h3>Autopilot</h3><p class="for">Para que el crecimiento no dependa de ti: automatización total.</p></article>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-block:clamp(80px,11vw,130px)">
    <div class="wrap">
      <div class="founder-band dark reveal">
        <div class="fb-glow"></div>
        <div class="fb-grid">
          <div>
            <h2 style="font-size:clamp(26px,4vw,40px)">5 empresas. Precio de fundador. Resultados garantizados.</h2>
            <p class="lead" style="margin-top:14px">Buscamos cinco negocios en crecimiento para trabajar de cerca a cambio de precio preferente y un caso de éxito compartido. Entra temprano en algo bueno.</p>
            <div class="fb-slots" aria-hidden="true"><span class="slot taken"></span><span class="slot taken"></span><span class="slot"></span><span class="slot"></span><span class="slot"></span></div>
            <p class="fb-count">2 de 5 lugares ocupados</p>
            <div class="hero-cta-row"><a class="btn btn-lime" href="/contacto">Aplicar al Programa Fundador</a></div>
          </div>
          <div class="fb-guarantee">
            <div class="g"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 12 l5 5 9-11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Precio fundador, congelado mientras seas cliente.</span></div>
            <div class="g"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 12 l5 5 9-11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Sin amarres: mes a mes, cancelas cuando quieras.</span></div>
            <div class="g"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 12 l5 5 9-11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Atención directa del fundador, no de un becario.</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section closer" id="faq">
    <div class="wrap">
      <div class="closer-grid">
        <div>
          <p class="eyebrow">Preguntas frecuentes</p>
          <h2>Lo que probablemente te estás preguntando.</h2>
          <div class="faq reveal">
            <div class="qa"><button class="q" aria-expanded="false">¿Son nuevos?<span class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path></svg></span></button><div class="a"><p>Sí, y lo decimos de frente. Por eso ofrecemos garantía de desempeño y un cupo fundador con precio preferente. Preferimos demostrar antes que presumir: nuestro escáner y nuestro propio sitio hablan por nosotros.</p></div></div>
            <div class="qa"><button class="q" aria-expanded="false">¿Cuánto cuesta?<span class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path></svg></span></button><div class="a"><p>El diagnóstico es gratis. A partir de ahí, cada nivel tiene un precio claro según el alcance — Cimientos es un proyecto puntual, Aceleración y Autopilot son mensuales. Sin sorpresas ni letras chiquitas.</p></div></div>
            <div class="qa"><button class="q" aria-expanded="false">¿Trabajan con mi plataforma?<span class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path></svg></span></button><div class="a"><p>Sí: WordPress, Shopify, Webflow, sitios a medida y más. El diagnóstico detecta tu stack automáticamente y adaptamos el plan a lo que ya tienes.</p></div></div>
          </div>
        </div>

        <div class="closer-cta">
          <h2>¿Listo para ver cuánto puede crecer tu web?</h2>
          <div class="cta-row">
            <a class="btn btn-lime" href="#scanner">Analizar mi web gratis</a>
            <a class="btn btn-ghost" href="/contacto">Agenda una llamada</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero-data { overflow: hidden; text-align: center; }
  .hero-statement { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 20px; margin-bottom: 52px; }
  .stat-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 18px; padding: 28px 20px; backdrop-filter: blur(8px); transition: all .3s ease; }
  .stat-card:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.14); }
  .stat-card.stat-primary { border-color: rgba(45, 90, 80, 0.4); }
  .stat-card.stat-warning { border-color: rgba(198, 93, 59, 0.4); }
  .stat-card.stat-critical { border-color: rgba(232, 149, 107, 0.4); }
  .stat-number { font-size: clamp(36px, 6vw, 52px); font-weight: 800; font-family: var(--mono); letter-spacing: -0.04em; margin-bottom: 8px; }
  .stat-primary .stat-number { color: #2D5A50; }
  .stat-warning .stat-number { color: #C65D3B; }
  .stat-critical .stat-number { color: #E8956B; }
  .stat-number .pct { font-size: 0.6em; }
  .stat-label { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 6px; }
  .stat-context { font-size: 12px; color: var(--muted); font-family: var(--mono); letter-spacing: 0.05em; }

  h1.hero-title { font-size: clamp(42px, 6.4vw, 74px); max-width: 20ch; margin-inline: auto; margin-bottom: 40px; }

  .before-after { display: grid; grid-template-columns: 1fr auto 1fr; gap: 28px; align-items: center; margin-bottom: 40px; max-width: 900px; margin-inline: auto; }
  @media (max-width: 820px) { .before-after { grid-template-columns: 1fr; gap: 32px; } }
  .ba-item { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 24px; }
  .ba-visual { height: 140px; margin-bottom: 16px; }
  .ba-visual svg { width: 100%; height: 100%; }
  .ba-broken svg { color: rgba(239, 68, 68, 0.5); }
  .ba-optimized svg { color: #C7F94B; }
  .ba-text { text-align: center; }
  .ba-title { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 12px; }
  .ba-metric { font-size: 13px; color: var(--muted); font-family: var(--mono); margin-bottom: 6px; }
  .ba-metric strong { color: var(--text); font-weight: 700; }
  .ba-arrow { display: flex; justify-content: center; }
  .ba-arrow svg { width: 40px; height: 40px; color: var(--lime); }
  @media (max-width: 820px) { .ba-arrow { display: none; } }

  .scanwrap { max-width: 640px; margin: 40px auto 0; text-align: left; }
  .hero-sub { font-size: 13.5px; color: var(--muted); margin-top: 16px; }

  .hero-cta-row { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; margin-top: 20px; align-items: center; }

  /* Prueba de PageSpeed, fusionada al hero (antes era su propia sección) */
  .hero-proof { margin-top: 56px; padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; gap: 30px; flex-wrap: wrap; }
  .pmsg { font-size: 14.5px; color: var(--muted); max-width: 38ch; text-align: left; }
  .pmsg b { color: var(--text); font-weight: 600; }
  .readout { display: flex; gap: 26px; flex-wrap: wrap; }
  .readout .rn { font-family: var(--mono); font-size: 24px; font-weight: 700; color: var(--lime); letter-spacing: -0.02em; }
  .readout .rn small { color: var(--muted); font-size: 14px; }
  .readout .rl { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--faint); margin-top: 3px; }
  @media (max-width: 640px) { .hero-proof { flex-direction: column; text-align: center; } .pmsg { text-align: center; } }

  .shead { max-width: 60ch; margin-bottom: 48px; }
  .shead h2 { font-size: clamp(28px, 4vw, 44px); }
  .shead p { margin-top: 16px; }

  .statband { text-align: center; padding-block: clamp(40px, 6vw, 64px); }
  .statband .big { font-size: clamp(30px, 5vw, 52px); font-weight: 700; letter-spacing: -0.03em; max-width: 20ch; margin-inline: auto; }
  .statband .big em { color: var(--violet-ink); font-style: normal; }
  .statband .src { font-family: var(--mono); font-size: 12px; color: var(--faint); margin-top: 20px; letter-spacing: 0.06em; }

  /* Pilares: 1 lead card + 3 en grid — rompe el patrón de 4 columnas iguales */
  .pillars { display: flex; flex-direction: column; gap: 16px; }
  .pcard { background: var(--surface); border: 1px solid var(--line-soft); border-radius: 16px; padding: 24px; box-shadow: var(--card-shadow); transition: border-color .2s ease, transform .2s ease; }
  .pcard:hover { border-color: var(--violet); transform: translateY(-3px); }
  .pcard-lead { display: flex; align-items: center; gap: 28px; padding: 32px; }
  .pcard-lead .pico { margin-bottom: 0; flex: none; width: 68px; height: 68px; }
  .pcard-lead .pico svg { width: 32px; height: 32px; }
  .pcard-lead h3 { font-size: 24px; }
  .pcard-lead .desc { max-width: 52ch; }
  @media (max-width: 640px) { .pcard-lead { flex-direction: column; align-items: flex-start; gap: 16px; } }
  .pillars-rest { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  @media (max-width: 820px) { .pillars-rest { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .pillars-rest { grid-template-columns: 1fr; } }
  .pico { width: 52px; height: 52px; border-radius: 14px; display: grid; place-items: center; margin-bottom: 20px; background: color-mix(in srgb, var(--violet) 14%, transparent); border: 1px solid color-mix(in srgb, var(--violet) 28%, transparent); color: var(--violet-ink); }
  .pico svg { width: 25px; height: 25px; }
  .pcard h3 { font-size: 20px; letter-spacing: -0.02em; }
  .pcard .hook { color: var(--text); font-size: 14.5px; margin-top: 8px; font-weight: 600; }
  .pcard .desc { color: var(--muted); font-size: 13.5px; margin-top: 12px; line-height: 1.55; }

  /* Método + Pricing fusionados en 2 columnas */
  .method-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(40px, 6vw, 80px); align-items: start; }
  @media (max-width: 900px) { .method-grid { grid-template-columns: 1fr; gap: 64px; } }
  .method-col .shead { margin-bottom: 32px; }

  .timeline { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0; }
  .timeline li { display: flex; gap: 18px; padding-block: 18px; border-left: 2px solid var(--line); padding-left: 22px; margin-left: 20px; position: relative; }
  .timeline li:last-child { border-left-color: transparent; }
  .step-ic { width: 40px; height: 40px; border-radius: 11px; display: grid; place-items: center; background: color-mix(in srgb, var(--violet) 13%, transparent); border: 1px solid color-mix(in srgb, var(--violet) 26%, transparent); color: var(--violet-ink); flex: none; margin-left: -41px; margin-top: -2px; }
  .step-ic svg { width: 19px; height: 19px; }
