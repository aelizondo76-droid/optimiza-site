---
import Base from '../../layouts/Base.astro';
import { getReport } from '../../lib/store';
import type { Diagnosis } from '../../lib/diagnose';

export const prerender = false;

const { id } = Astro.params;
const report = (await getReport<Diagnosis>(id!)) ?? null;

const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString('es-CR', { year: 'numeric', month: 'long', day: 'numeric' });

const scoreColor = (n: number) => (n >= 80 ? 'var(--lime)' : n >= 55 ? '#FFB454' : '#FF6B7A');
const pillarIntro: Record<string, string> = {
  velocidad: 'Qué tan rápido carga y responde tu sitio en dispositivos reales.',
  visibilidad: 'Qué tan bien te encuentran Google y los buscadores de IA.',
  conversion: 'Qué tan bien tu sitio convierte visitantes en clientes.',
  automatizacion: 'Si estás midiendo y puedes automatizar tu captación.',
};

const mob = report?.speed.mobile;
const desk = report?.speed.desktop;
const cwv = mob
  ? [
      { k: 'LCP', label: 'Carga (LCP)', v: mob.lcp != null ? `${mob.lcp}s` : '—', good: mob.lcp != null && mob.lcp <= 2.5, warn: mob.lcp != null && mob.lcp <= 4 },
      { k: 'CLS', label: 'Estabilidad (CLS)', v: mob.cls != null ? mob.cls.toFixed(3) : '—', good: mob.cls != null && mob.cls <= 0.1, warn: mob.cls != null && mob.cls <= 0.25 },
      { k: 'TBT', label: 'Interacción (TBT)', v: mob.tbt != null ? `${mob.tbt}ms` : '—', good: mob.tbt != null && mob.tbt <= 200, warn: mob.tbt != null && mob.tbt <= 600 },
      { k: 'SI', label: 'Speed Index', v: mob.speedIndex != null ? `${mob.speedIndex}s` : '—', good: mob.speedIndex != null && mob.speedIndex <= 3.4, warn: mob.speedIndex != null && mob.speedIndex <= 5.8 },
    ]
  : [];

const title = report ? `Diagnóstico de ${report.host} — Optimiza` : 'Informe no encontrado — Optimiza';
const description = report
  ? `${report.host} obtuvo ${report.index}/100 en el Índice Optimiza. Velocidad, visibilidad, conversión y automatización.`
  : 'Informe no disponible.';
---
<Base title={title} description={description}>
  <meta slot="head" name="robots" content="noindex" />

  {!report ? (
    <section class="section"><div class="wrap nf">
      <h1>Informe no encontrado</h1>
      <p class="lead">Este diagnóstico expiró o el enlace no es válido.</p>
      <a class="btn btn-violet" href="/#top">Analizar mi web gratis</a>
    </div></section>
  ) : (
    <>
    <section class="section rep-hero dark">
      <div class="wrap">
        <p class="eyebrow">Diagnóstico Optimiza · {fmtDate(report.fetchedAt)}</p>
        <div class="rh-grid">
          <div class="rh-main">
            <h1>{report.host}</h1>
            <p class="lead">Índice Optimiza — la salud comercial de tu web en un número, medido en los 4 pilares.</p>
            <div class="rh-badges">
              {report.stack && <span class="chip">Plataforma: {report.stack}</span>}
              <a class="chip lnk" href={report.finalUrl} target="_blank" rel="noopener nofollow">Ver sitio ↗</a>
            </div>
          </div>
          <div class="rh-score">
            <div class="big-gauge">
              <svg viewBox="0 0 200 120" aria-hidden="true">
                <path d="M12 112 A88 88 0 0 1 188 112" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="13" stroke-linecap="round"></path>
                <path d="M12 112 A88 88 0 0 1 188 112" fill="none" stroke={scoreColor(report.index)} stroke-width="13" stroke-linecap="round" pathLength="100" stroke-dasharray="100" style={`stroke-dashoffset:${100 - report.index};filter:drop-shadow(0 0 9px ${scoreColor(report.index)}55)`}></path>
              </svg>
              <div class="bg-val">
                <div class="bg-num" style={`color:${scoreColor(report.index)}`}>{report.index}<small>/100</small></div>
                <div class="bg-grade">Calificación {report.grade}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section rep-pillars">
      <div class="wrap">
        <div class="pil-grid">
          {report.pillars.map((p) => (
            <div class="pil-card">
              <div class="pc-head">
                <div>
                  <h2>{p.label}</h2>
                  <p class="pc-intro">{pillarIntro[p.key]}</p>
                </div>
                <div class="pc-score" style={`color:${scoreColor(p.score)}`}>{p.score}</div>
              </div>
              <div class="pc-bar"><span style={`width:${p.score}%;background:${scoreColor(p.score)}`}></span></div>
              <ul class="pc-find">
                {p.findings.map((f) => (
                  <li class={f.ok === true ? 'ok' : f.ok === 'warn' ? 'warn' : 'bad'}>
                    <span class="fi-ico">{f.ok === true ? '✓' : f.ok === 'warn' ? '!' : '✗'}</span>
                    <span class="fi-tx">{f.title}{f.detail && <em> — {f.detail}</em>}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section rep-speed dark">
      <div class="wrap">
        <p class="eyebrow">Velocidad · Core Web Vitals</p>
        <div class="sp-grid">
          <div class="sp-perf">
            <div class="perf-cell">
              <div class="pf-n" style={mob?.performance != null ? `color:${scoreColor(mob.performance)}` : ''}>{mob?.performance ?? '—'}</div>
              <div class="pf-l">Rendimiento móvil</div>
            </div>
            <div class="perf-cell">
              <div class="pf-n" style={desk?.performance != null ? `color:${scoreColor(desk.performance)}` : ''}>{desk?.performance ?? '—'}</div>
              <div class="pf-l">Rendimiento escritorio</div>
            </div>
          </div>
          <div class="sp-cwv">
            {cwv.map((c) => (
              <div class="cwv-cell">
                <div class="cw-top"><span class="cw-l">{c.label}</span><span class={`cw-dot ${c.good ? 'g' : c.warn ? 'w' : 'b'}`}></span></div>
                <div class="cw-v">{c.v}</div>
              </div>
            ))}
          </div>
        </div>
        {mob?.opportunities && mob.opportunities.length > 0 && (
          <div class="sp-opps">
            <h3>Oportunidades de velocidad detectadas</h3>
            <ul>
              {mob.opportunities.map((o) => (
                <li><span class="op-tx">{o.title}</span><span class="op-ms">~{(o.savingsMs / 1000).toFixed(1)}s</span></li>
              ))}
            </ul>
          </div>
        )}
        {report.screenshot && (
          <div class="sp-shot">
            <p class="shot-cap">Así ve Google tu sitio en móvil</p>
            <img src={report.screenshot} alt={`Captura de ${report.host} en móvil`} loading="lazy" />
          </div>
        )}
      </div>
    </section>

    <section class="section rep-cta">
      <div class="wrap cta-band">
        <div>
          <h2>Este diagnóstico es el mapa. Nosotros lo ejecutamos.</h2>
          <p class="lead">Convertimos cada hallazgo en un plan priorizado por impacto en tus ventas — no en reportes.</p>
        </div>
        <div class="cta-acts">
          <a class="btn btn-lime" href="/contacto">Agenda tu llamada</a>
          <a class="btn btn-ghost" href="/servicios">Ver cómo trabajamos</a>
        </div>
      </div>
    </section>
    </>
  )}
</Base>

<style>
  .nf { text-align: center; padding-block: 40px; }
  .nf .btn { margin-top: 24px; }

  .rep-hero { background: linear-gradient(180deg, var(--surface-2), var(--bg)); border-bottom: 1px solid var(--line); }
  .rh-grid { display: grid; grid-template-columns: 1fr auto; gap: 40px; align-items: center; margin-top: 8px; }
  @media (max-width: 720px) { .rh-grid { grid-template-columns: 1fr; } }
  .rh-main h1 { font-size: clamp(34px, 6vw, 54px); word-break: break-word; }
  .rh-main .lead { margin-top: 14px; }
  .rh-badges { display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap; }
  .chip { font-family: var(--mono); font-size: 12px; color: var(--muted); border: 1px solid var(--line); border-radius: 999px; padding: 7px 14px; }
  .chip.lnk { color: var(--cyan-ink); }
  .big-gauge { position: relative; width: 240px; }
  .big-gauge svg { width: 240px; height: 144px; display: block; }
  .big-gauge svg path:nth-child(2) { transition: stroke-dashoffset 1.4s cubic-bezier(.2,.7,.2,1); }
  .bg-val { position: absolute; left: 0; right: 0; bottom: 4px; text-align: center; }
  .bg-num { font-family: var(--mono); font-weight: 700; font-size: 54px; line-height: 1; letter-spacing: -0.04em; }
  .bg-num small { font-size: 20px; color: var(--muted); }
  .bg-grade { font-family: var(--mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin-top: 8px; }

  .pil-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  @media (max-width: 720px) { .pil-grid { grid-template-columns: 1fr; } }
  .pil-card { border: 1px solid var(--line); border-radius: 18px; padding: 26px; background: var(--surface); box-shadow: var(--card-shadow); }
  .pc-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; }
  .pc-head h2 { font-size: 22px; }
  .pc-intro { color: var(--muted); font-size: 13.5px; margin-top: 6px; max-width: 34ch; }
  .pc-score { font-family: var(--mono); font-weight: 700; font-size: 40px; letter-spacing: -0.03em; line-height: 1; }
  .pc-bar { height: 7px; background: rgba(23,20,31,0.08); border-radius: 99px; overflow: hidden; margin: 18px 0 20px; }
  .pc-bar span { display: block; height: 100%; border-radius: 99px; }
  .pc-find { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 11px; }
  .pc-find li { display: flex; gap: 11px; font-size: 14px; line-height: 1.45; align-items: flex-start; }
  .pc-find .fi-ico { flex: none; width: 20px; height: 20px; border-radius: 6px; display: grid; place-items: center; font-size: 12px; font-weight: 700; margin-top: 1px; }
  .pc-find li.ok .fi-ico { background: rgba(52,168,83,0.14); color: #2E9E4C; }
  .pc-find li.warn .fi-ico { background: rgba(217,119,6,0.14); color: #C77605; }
  .pc-find li.bad .fi-ico { background: rgba(220,38,38,0.13); color: #DC3B3B; }
  .pc-find .fi-tx { color: var(--text); }
  .pc-find em { color: var(--muted); font-style: normal; }

  .rep-speed { background: var(--surface-2); }
  .sp-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 20px; margin-top: 8px; }
  @media (max-width: 720px) { .sp-grid { grid-template-columns: 1fr; } }
  .sp-perf { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .perf-cell, .cwv-cell { border: 1px solid var(--line); border-radius: 14px; padding: 20px; background: var(--surface); text-align: center; }
  .pf-n { font-family: var(--mono); font-weight: 700; font-size: 44px; letter-spacing: -0.03em; line-height: 1; color: var(--text); }
  .pf-l { font-size: 12px; color: var(--muted); margin-top: 8px; }
  .sp-cwv { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  @media (max-width: 560px) { .sp-cwv { grid-template-columns: 1fr 1fr; } }
  .cwv-cell { text-align: left; padding: 16px; }
  .cw-top { display: flex; justify-content: space-between; align-items: center; }
  .cw-l { font-size: 11px; color: var(--muted); }
  .cw-dot { width: 9px; height: 9px; border-radius: 50%; }
  .cw-dot.g { background: #2E9E4C; } .cw-dot.w { background: #D9840A; } .cw-dot.b { background: #DC3B3B; }
  .cw-v { font-family: var(--mono); font-weight: 700; font-size: 22px; margin-top: 12px; letter-spacing: -0.02em; }

  .sp-opps { margin-top: 28px; }
  .sp-opps h3 { font-size: 15px; font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 14px; font-weight: 600; }
  .sp-opps ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .sp-opps li { display: flex; justify-content: space-between; gap: 16px; padding: 13px 16px; border: 1px solid var(--line); border-radius: 11px; background: var(--surface); font-size: 14px; }
  .sp-opps .op-ms { font-family: var(--mono); color: #FFB454; font-weight: 700; flex: none; }

  .sp-shot { margin-top: 28px; }
  .shot-cap { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--muted); margin-bottom: 12px; }
  .sp-shot img { max-width: 300px; border-radius: 14px; border: 1px solid var(--line); box-shadow: var(--card-shadow); }

  .cta-band { display: flex; justify-content: space-between; align-items: center; gap: 28px; border: 1px solid var(--line); border-radius: 22px; padding: 40px; background: linear-gradient(120deg, var(--surface), var(--surface-2)); box-shadow: var(--card-shadow); flex-wrap: wrap; }
  .cta-band h2 { font-size: clamp(24px, 3.5vw, 34px); max-width: 20ch; }
  .cta-band .lead { margin-top: 12px; max-width: 46ch; }
  .cta-acts { display: flex; gap: 12px; flex-wrap: wrap; }
</style>
