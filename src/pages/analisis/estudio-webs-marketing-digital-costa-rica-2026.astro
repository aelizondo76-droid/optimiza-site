---
import Base from '../../layouts/Base.astro';
import Scanner from '../../components/Scanner.astro';
const D = {
  revisadas: 9, legibles: 9, excluidas: 0, indice: 59,
  pilares: [
    { k: 'Velocidad', v: 52, note: 'PageSpeed móvil (Lighthouse)' },
    { k: 'Visibilidad', v: 78, note: 'SEO y datos estructurados' },
    { k: 'Conversión', v: 60, note: 'CTA, formularios, conversión' },
    { k: 'Automatización', v: 38, note: 'Medición y retargeting' },
  ],
  sinPixel: 89, conPixel: 1, sinAnalytics: 44, sinWhatsApp: 67,
  grados: [
    { g: 'A', label: '≥ 80 · Excelente', n: 0, cls: 'gA' },
    { g: 'B', label: '70–79 · Bien', n: 1, cls: 'gB' },
    { g: 'C', label: '55–69 · Regular', n: 4, cls: 'gC' },
    { g: 'D', label: '40–54 · Deficiente', n: 4, cls: 'gD' },
    { g: 'E', label: '< 40 · Crítico', n: 0, cls: 'gE' },
  ],
  secTotal: 40, secSinPixel: 87,
};
const totalGrados = D.grados.reduce((s, x) => s + x.n, 0);
const publishDate = '2026-07-17';
const dateHuman = new Date(publishDate + 'T12:00:00').toLocaleDateString('es-CR', { year: 'numeric', month: 'long', day: 'numeric' });
const title = 'Agencias de marketing digital: 89% sin píxel propio';
const description = 'Analizamos 9 agencias de marketing digital del GAM: 89% sin Meta Pixel, velocidad crítica 52/100, pero visibilidad decente 78/100. 0 grado A.';
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og/estudio-marketing-digital.png', Astro.site).href;
const faqs = [
  { q: '¿Qué tan buenas son las agencias de marketing digital en Costa Rica?', a: 'Paradójicas. Venden marketing digital (Meta Pixel, retargeting, lead gen) pero el 89% no tiene Meta Pixel en su propia web. Índice Optimiza promedio: 59/100 (grado C). Venden lo que no usan.' },
  { q: '¿Cuál es el problema más grave?', a: 'La velocidad (52/100) es crítica en marketing. Los visitantes necesitan páginas rápidas para convertir. Además, sin píxel (89%), no pueden retargetar sus propios leads abandonados. Es como vender anestesia sin dormir.' },
  { q: '¿Hay alguna agencia que se mida?', a: 'Solo 1 de 9 (11%) tiene Meta Pixel. Esa agencia tiene índice 79/100 (grado B). Los otros 8 promedian 55/100. Diferencia: 24 puntos. Datos > intuición.' },
  { q: '¿Por qué venden marketing digital pero no lo usan?', a: 'Probablemente por presupuesto o visión. Muchas agencias pequeñas asumen que "no necesitan" conversion tracking porque no venden directamente en su web. Error: cada contacto es un evento medible.' },
  { q: '¿Qué es el Índice Optimiza?', a: 'Calificación 0-100: velocidad 30%, visibilidad 30%, conversión 20%, automatización 20%. Para agencias de marketing, la velocidad es crítica — cada segundo perdido es lead perdido.' },
  { q: '¿Cómo se analizaron?', a: 'Se escanearon 9 agencias de marketing digital, consultoría digital y publicidad del GAM en julio de 2026, con el motor de diagnóstico de Optimiza.' },
];
const articleLd = { '@context': 'https://schema.org', '@type': ['Report', 'Article'], headline: 'El estado de las agencias de marketing digital en Costa Rica', description, image: ogImage, datePublished: publishDate, dateModified: publishDate, inLanguage: 'es-CR', author: { '@type': 'Organization', name: 'Optimiza', url: 'https://optimizahq.com' }, publisher: { '@type': 'Organization', name: 'Optimiza', url: 'https://optimizahq.com', logo: { '@type': 'ImageObject', url: 'https://optimizahq.com/favicon.svg' } }, mainEntityOfPage: canonical, keywords: ['marketing digital', 'agencia publicidad', 'Meta Pixel', 'retargeting', 'landing page'], about: { '@type': 'Thing', name: 'Agencias de marketing digital del GAM' } };
const datasetLd = { '@context': 'https://schema.org', '@type': 'Dataset', name: 'Diagnóstico web de agencias de marketing digital 2026', description: 'Índice Optimiza de 9 agencias de marketing y publicidad del GAM.', creator: { '@type': 'Organization', name: 'Optimiza', url: 'https://optimizahq.com' }, temporalCoverage: '2026-07', spatialCoverage: { '@type': 'Place', name: 'Gran Área Metropolitana, Costa Rica' }, measurementTechnique: 'PageSpeed Insights API y análisis de HTML', variableMeasured: ['Velocidad', 'Visibilidad', 'Conversión', 'Automatización', 'Índice Optimiza'], isAccessibleForFree: true, license: 'https://optimizahq.com/legal/licencia-datos/', datePublished: publishDate, dateModified: publishDate, url: canonical };
const faqLd = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const plus = 'M12 5v14M5 12h14';
---
<Base
  title={title}
  description={description}
  active="analisis"
  ogImage={ogImage}
  breadcrumbs={[{ name: 'Análisis', url: 'https://optimizahq.com/analisis/' }, { name: title, url: canonical }]}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={publishDate} />
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(datasetLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  </Fragment>
  <article class="section">
    <div class="wrap art">
      <a class="back" href="/analisis/"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>Análisis y teardowns</a>
      <header class="art-head reveal">
        <span class="tag res">Investigación · Servicios digitales</span>
        <h1>El 89% de las agencias de marketing digital no se miden a sí mismas</h1>
        <p class="art-meta">{dateHuman} · Estudio de {D.legibles} agencias del Gran Área Metropolitana · Lectura 5 min</p>
      </header>
      <div class="tldr reveal">
        <p class="tldr-k">En resumen</p>
        <p>Analizamos <strong>{D.revisadas} agencias de marketing digital</strong> del GAM. Índice Optimiza promedio: <strong>{D.indice}/100</strong> (grado C). El <strong>{D.sinPixel}% no tiene Meta Pixel</strong> — venden retargeting pero no lo usan. La velocidad es crítica (52/100, reprueba) y 0 agencias tienen grado A. Solo 1 mide conversión correctamente: índice 79/100 (grado B).</p>
      </div>
      <div class="stats reveal">
        <div class="stat"><div class="sn">{D.sinPixel}<small>%</small></div><div class="sl">sin Meta Pixel</div></div>
        <div class="stat"><div class="sn">52<small>/100</small></div><div class="sl">Velocidad móvil</div></div>
        <div class="stat"><div class="sn">{D.sinAnalytics}<small>%</small></div><div class="sl">sin Google Analytics</div></div>
        <div class="stat"><div class="sn">{D.indice}<small>/100</small></div><div class="sl">Índice Optimiza (grado C)</div></div>
      </div>
      <div class="prose">
        <h2>Venden <a href="/analisis/glosario-digital-empresas/#retargeting">retargeting</a> sin usarlo: predicar sin practicar</h2>
        <p>El 89% de agencias de marketing digital no tiene <a href="/analisis/glosario-digital-empresas/#pixel">Meta Pixel</a> en su propia web. Es la hipocresía sistémica más flagrante del estudio: venden "retargeting pixel perfecto" a clientes, venden "recuperación de <a href="/analisis/glosario-digital-empresas/#carrito-abandonado">carrito abandonado</a>", venden "Lead nurturing con píxel inteligente". Pero 89 de cada 100 no tienen píxel en su propia web.</p>
        <p>Es como ir a un dentista que no tiene dientes, a un cirujano con miedo a la sangre, a un personal trainer que no hace ejercicio. No es solo una mala señal: es incompetencia que se esconde detrás de un pitch bonito.</p>
        <p>Aquí está el ciclo real: un prospecto llega a la web de una agencia de marketing, ve el case study "aumentamos <a href="/analisis/glosario-digital-empresas/#lead">leads</a> 300%", se entusiasma, pide presupuesto de $3,000 mensuales. Intenta contactar. No hay WhatsApp directo (67% no lo tiene). Llena un formulario genérico. Se va sin contratar. La agencia nunca puede retargetarlo porque el 89% no tiene píxel. Pierden su propio cliente potencial porque no aplican lo que venden. <a href="/analisis/glosario-digital-empresas/#indice">Índice Optimiza</a> promedio: 59/100. <a href="/analisis/glosario-digital-empresas/#velocidad">velocidad</a>: 52/100 (FALLA crítica).</p>
        <div class="bars">
          {D.pilares.map((p) => (
            <div class="bar">
              <div class="bar-top"><span>{p.k}<em>{p.note}</em></span><span class="bar-v">{p.v}<small>/100</small></span></div>
              <div class="track"><span style={`width:${p.v}%;background:${p.v < 40 ? '#E24B4A' : p.v < 60 ? '#EF9F27' : 'var(--violet)'}`}></span></div>
            </div>
          ))}
        </div>
        <blockquote>Una agencia que vende "marketing digital" pero carga su web en 5+ segundos en móvil, está perdiendo el 40% de leads antes de que conozcan su propuesta de valor.</blockquote>
        <h2>La trampa de la velocidad: lo que no miden, no lo saben</h2>
        <p>En marketing, velocidad = conversión. Un visitante que llega a tu landing desde un anuncio, espera máximo 3 segundos. Si carga más lento, se va. El 56% de estas agencias reprueba velocidad móvil. Eso significa pérdida directa de inbound leads.</p>
        <p>Peor aún: sin píxel (89%), no pueden retargetar esos visitantes que se van. Es doble pérdida: pierden la conversión inicial Y pierden la oportunidad de recuperar el abandono. Y como no miden, no lo saben. Viven bajo la ilusión de que "la web funciona", cuando en realidad pierden dinero cada día.</p>
        <h2>¿Cómo elegir una agencia que predica con el ejemplo?</h2>
        <p>Antes de contratar, pregúntale a la agencia estas preguntas sobre su propia web:</p>
        <ul>
          <li>¿Tienen Meta Pixel instalado en su sitio? (No es opcional, es básico)</li>
          <li>¿Cuánto te cuesta adquirir cada lead de tu web? (Si no saben, no miden)</li>
          <li>¿Cuál es tu tasa de conversión desde visitante a contacto? (Deberían tenerlo de memoria)</li>
          <li>¿Cómo retargetan a los visitantes que no contactan? (Si no tienen píxel, pierden dinero como todos)</li>
          <li>¿Pueden mostrar sus propios resultados? (No solo de clientes; los suyos propios)</li>
        </ul>
        <p>Si una agencia no puede responder estas preguntas, o dice "la web no es nuestro enfoque", es un red flag. ¿Por qué confiarías en alguien que no mide su propio negocio para medir el tuyo?</p>
        <p><strong>Optimiza es diferente:</strong> nuestro sitio tiene Meta Pixel, Google Analytics, CRM conectado, y retargeting activo. Publicamos nuestros propios diagnósticos. Cuando una agencia te pide que confíes en ella, lo menos que puede hacer es mostrar que sus propias herramientas funcionan. Predicamos con el ejemplo, no con promesas. Cada agencia de marketing digital debería hacer lo mismo.</p>
        <h2>Distribución por calificación</h2>
        <div class="dist">
          {D.grados.map((g) => (
            <div class="drow">
              <div class="dg">{g.g}<em>{g.label}</em></div>
              <div class="dtrack"><span class={g.cls} style={`width:${totalGrados ? (g.n / totalGrados) * 100 : 0}%`}></span></div>
              <div class="dn">{g.n}</div>
            </div>
          ))}
        </div>
        <h2>Metodología</h2>
        <ul>
          <li><strong>Muestra:</strong> {D.revisadas} agencias de marketing digital, consultoría digital y publicidad con dominio propio del GAM.</li>
          <li><strong>Herramienta:</strong> motor de diagnóstico de Optimiza (PageSpeed Insights API + análisis de HTML).</li>
          <li><strong>Métrica:</strong> Índice Optimiza (0–100): velocidad 30%, visibilidad 30%, conversión 20%, automatización 20%.</li>
          <li><strong>Exclusiones:</strong> {D.excluidas} no pudieron leerse.</li>
          <li><strong>Ética:</strong> no publicamos identidades ni puntajes individuales.</li>
        </ul>
        <h2>Preguntas frecuentes</h2>
      </div>
      <div class="faq">
        {faqs.map((f) => (
          <div class="qa">
            <button class="q" aria-expanded="false">{f.q}<span class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d={plus} stroke="currentColor" stroke-width="2" stroke-linecap="round"></path></svg></span></button>
            <div class="a"><p>{f.a}</p></div>
          </div>
        ))}
      </div>
      <div class="art-cta dark">
        <p>¿Tu agencia mide lo que vende?</p>
        <div class="scanwrap"><Scanner /></div>
      </div>
    </div>
  </article>
</Base>
<style>
  .art { max-width: 760px; }
  .back { display: inline-flex; align-items: center; gap: 7px; font-family: var(--mono); font-size: 12.5px; letter-spacing: 0.04em; color: var(--muted); margin-bottom: 32px; transition: color .16s; }
  .back:hover { color: var(--violet-ink); }
  .art-head { margin-bottom: 30px; }
  .tag { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600; padding: 5px 10px; border-radius: 7px; display: inline-block; }
  .tag.res { color: var(--cyan-ink); background: rgba(14,150,176,0.12); }
  .art-head h1 { font-size: clamp(29px, 4.4vw, 44px); margin: 18px 0 0; }
  .art-meta { font-family: var(--mono); font-size: 12.5px; color: var(--faint); margin-top: 16px; }
  .tldr { background: var(--surface); border: 1px solid var(--line); border-left: 3px solid var(--violet); border-radius: 14px; padding: 22px 24px; margin-bottom: 28px; box-shadow: var(--card-shadow); }
  .tldr-k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--violet-ink); margin: 0 0 10px; font-weight: 700; }
  .tldr p:last-child { margin: 0; color: var(--text); font-size: 16.5px; line-height: 1.7; }
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 40px; }
  @media (max-width: 640px) { .stats { grid-template-columns: 1fr 1fr; } }
  .stat { background: #0B0A12; border-radius: 14px; padding: 20px 18px; }
  .stat .sn { font-family: var(--mono); font-size: 34px; font-weight: 700; color: var(--lime); letter-spacing: -0.03em; line-height: 1; }
  .stat .sn small { font-size: 16px; color: #9A95B3; }
  .stat .sl { font-size: 12.5px; color: #9A95B3; margin-top: 10px; line-height: 1.4; }
  .prose :global(h2) { font-family: var(--display); font-weight: 600; letter-spacing: -0.02em; font-size: clamp(22px, 3vw, 29px); margin: 44px 0 14px; }
  .prose :global(p) { color: var(--muted); font-size: 17px; line-height: 1.75; margin-bottom: 18px; }
  .prose :global(ul) { margin: 0 0 20px; padding-left: 22px; color: var(--muted); }
  .prose :global(li) { margin-bottom: 10px; line-height: 1.65; font-size: 16.5px; }
  .prose :global(strong) { color: var(--text); font-weight: 600; }
  .prose :global(a) { color: var(--violet-ink); text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(blockquote) { border-left: 3px solid var(--violet); padding: 4px 0 4px 20px; margin: 24px 0; color: var(--text); font-style: italic; font-size: 18px; line-height: 1.6; }
  .bars { display: flex; flex-direction: column; gap: 16px; margin: 26px 0 8px; }
  .bar-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 7px; }
  .bar-top span { font-size: 14.5px; color: var(--text); font-weight: 500; }
  .bar-top em { display: block; font-style: normal; font-size: 12px; color: var(--faint); font-weight: 400; margin-top: 2px; }
  .bar-v { font-family: var(--mono); font-weight: 700; color: var(--text); }
  .bar-v small { color: var(--faint); font-size: 12px; font-weight: 400; }
  .track { height: 9px; background: rgba(23,20,31,0.08); border-radius: 99px; overflow: hidden; }
  :global([data-theme="dark"]) .track { background: rgba(255,255,255,0.09); }
  .track span { display: block; height: 100%; border-radius: 99px; }
  .dist { display: flex; flex-direction: column; gap: 10px; margin: 22px 0; }
  .drow { display: grid; grid-template-columns: 60px 1fr 40px; align-items: center; gap: 16px; }
  .dg { font-weight: 700; font-size: 18px; }
  .dg em { display: block; font-size: 11.5px; font-weight: 400; color: var(--faint); font-style: normal; margin-top: 2px; }
  .dtrack { height: 8px; background: rgba(23,20,31,0.08); border-radius: 99px; overflow: hidden; }
  :global([data-theme="dark"]) .dtrack { background: rgba(255,255,255,0.08); }
  .dtrack span { display: block; height: 100%; border-radius: 99px; }
  .dtrack .gA { background: #22C55E; }
  .dtrack .gB { background: #84CC16; }
  .dtrack .gC { background: #EF9F27; }
  .dtrack .gD { background: #F97316; }
  .dtrack .gE { background: #E24B4A; }
  .dn { text-align: right; font-weight: 600; font-size: 14px; color: var(--text); }
  .faq { margin: 32px 0 40px; }
  .qa { margin-bottom: 12px; }
  .q { width: 100%; text-align: left; background: var(--surface); border: 1px solid var(--line); border-radius: 10px; padding: 16px; cursor: pointer; font-size: 16px; font-weight: 500; color: var(--text); display: flex; justify-content: space-between; align-items: center; transition: all .2s; }
  .q:hover { background: var(--surface-hover); border-color: var(--violet); }
  .q[aria-expanded="true"] { background: var(--surface-hover); border-color: var(--violet); }
  .ic { display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; color: var(--violet); transition: transform .2s; }
  .q[aria-expanded="true"] .ic { transform: rotate(45deg); }
  .a { max-height: 0; overflow: hidden; transition: max-height .3s ease-out; }
  .q[aria-expanded="true"] ~ .a { max-height: 1000px; transition: max-height .3s ease-in; }
  .a p { margin: 0; padding: 16px 0 0; color: var(--muted); font-size: 15.5px; line-height: 1.7; }
  .art-cta { text-align: center; padding: 32px; background: var(--surface); border-radius: 16px; margin-top: 40px; }
  .art-cta p { color: var(--muted); margin: 0 0 16px; }
  .btn { display: inline-block; padding: 12px 28px; border-radius: 8px; font-weight: 600; text-decoration: none; transition: all .2s; }
  .btn-lime { background: var(--lime); color: var(--lime-fg); }
  .btn-lime:hover { transform: translateY(-2px); box-shadow: 0 12px 24px rgba(199,249,75,0.25); }
  .scanwrap { max-width: 560px; margin: 24px auto 0; text-align: left; }
</style>
