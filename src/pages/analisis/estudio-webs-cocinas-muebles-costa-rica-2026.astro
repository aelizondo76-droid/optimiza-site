---
import Base from '../../layouts/Base.astro';
import Scanner from '../../components/Scanner.astro';
const D = {
  revisadas: 25, legibles: 23, excluidas: 2, indice: 59,
  pilares: [
    { k: 'Visibilidad', v: 72, note: 'SEO y datos estructurados' },
    { k: 'Conversión', v: 66, note: 'CTA, formularios, WhatsApp' },
    { k: 'Velocidad', v: 60, note: 'PageSpeed móvil (Lighthouse)' },
    { k: 'Automatización', v: 33, note: 'Medición y retargeting' },
  ],
  sinPixel: 88, conPixel: 3, sinAnalytics: 47, sinWhatsApp: 52,
  grados: [
    { g: 'A', label: '≥ 80 · Excelente', n: 0, cls: 'gA' },
    { g: 'B', label: '70–79 · Bien', n: 4, cls: 'gB' },
    { g: 'C', label: '55–69 · Regular', n: 14, cls: 'gC' },
    { g: 'D', label: '40–54 · Deficiente', n: 5, cls: 'gD' },
    { g: 'E', label: '< 40 · Crítico', n: 2, cls: 'gE' },
  ],
  secTotal: 90, secSinPixel: 93,
};
const totalGrados = D.grados.reduce((s, x) => s + x.n, 0);
const publishDate = '2026-07-16';
const dateHuman = new Date(publishDate + 'T12:00:00').toLocaleDateString('es-CR', { year: 'numeric', month: 'long', day: 'numeric' });
const title = 'Fabricantes de cocinas en Costa Rica: el 88% no mide su web';
const description = 'Analizamos 25 fabricantes de cocinas y muebles a medida del GAM: muestran un producto hermoso, pero el 88% no tiene Meta Pixel. Datos y metodología.';
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og/estudio-cocinas-muebles.png', Astro.site).href;
const faqs = [
  { q: '¿Qué tan buenas son las webs de los fabricantes de cocinas y muebles a medida en Costa Rica?', a: 'Cumplen en imagen, fallan en medición. En un estudio de 25 fabricantes de cocinas y muebles a medida del Gran Área Metropolitana, el Índice Optimiza promedio fue de 59 sobre 100 (grado C). Muestran bien su producto, pero el 88% no puede medir ni recuperar a quien visita su web.' },
  { q: '¿Cuál es el problema más común?', a: 'La falta de medición. El 88% de los fabricantes analizados no tiene el píxel de Meta y casi la mitad no usa Google Analytics. Invierten en fotos y catálogo, pero no saben qué visita se convierte en cotización.' },
  { q: '¿Es igual en todo el sector construcción?', a: 'Sí. Sumado a constructoras, acabados y piscinas, el 93% de las 90 empresas de construcción del GAM analizadas no puede medir su web. Es un vacío transversal.' },
  { q: '¿Qué es el Índice Optimiza?', a: 'Una calificación de 0 a 100 que resume la salud de un sitio web en cuatro pilares: velocidad (30%), visibilidad o SEO (30%), conversión (20%) y automatización o medición (20%). Se calcula con la API de PageSpeed Insights de Google más un análisis del HTML.' },
  { q: '¿Cómo se realizó el estudio?', a: 'Se analizaron 25 fabricantes de cocinas y muebles a medida con dominio propio del Gran Área Metropolitana en julio de 2026, con el motor de diagnóstico de Optimiza (PageSpeed Insights API y análisis de HTML). 23 arrojaron datos completos.' },
];
const articleLd = { '@context': 'https://schema.org', '@type': ['Report', 'Article'], headline: 'El 88% de los fabricantes de cocinas de Costa Rica no mide su web', description, image: ogImage, datePublished: publishDate, dateModified: publishDate, inLanguage: 'es-CR', author: { '@type': 'Organization', name: 'Optimiza', url: 'https://optimizahq.com' }, publisher: { '@type': 'Organization', name: 'Optimiza', url: 'https://optimizahq.com', logo: { '@type': 'ImageObject', url: 'https://optimizahq.com/favicon.svg' } }, mainEntityOfPage: canonical, keywords: ['cocinas a medida Costa Rica', 'muebles a medida', 'fabricantes de cocinas', 'Meta Pixel', 'marketing construcción'], about: { '@type': 'Thing', name: 'Páginas web de fabricantes de cocinas y muebles a medida en Costa Rica' } };
const datasetLd = { '@context': 'https://schema.org', '@type': 'Dataset', name: 'Diagnóstico web de fabricantes de cocinas y muebles del GAM 2026', description: 'Índice Optimiza de 23 fabricantes de cocinas y muebles a medida del Gran Área Metropolitana.', creator: { '@type': 'Organization', name: 'Optimiza', url: 'https://optimizahq.com' }, temporalCoverage: '2026-07', spatialCoverage: { '@type': 'Place', name: 'Gran Área Metropolitana, Costa Rica' }, measurementTechnique: 'PageSpeed Insights API (Lighthouse) y análisis de HTML', variableMeasured: ['Velocidad', 'Visibilidad', 'Conversión', 'Automatización', 'Índice Optimiza'], isAccessibleForFree: true, license: 'https://optimizahq.com/legal/licencia-datos/', datePublished: publishDate, dateModified: publishDate, url: canonical };
const faqLd = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const plus = 'M12 5v14M5 12h14';
---
<Base
  title={title}
  description={description}
  active="analisis"
  ogImage={ogImage}
  breadcrumbs={[{ name: 'Análisis', url: 'https://optimizahq.com/analisis/' }, { name: title, url: canonical }]}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={publishDate} />
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(datasetLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  </Fragment>
  <article class="section">
    <div class="wrap art">
      <a class="back" href="/analisis/"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>Análisis y teardowns</a>
      <header class="art-head reveal">
        <span class="tag res">Investigación · Construcción</span>
        <h1>El 88% de los fabricantes de cocinas y muebles a medida no mide su web</h1>
        <p class="art-meta">{dateHuman} · Estudio de {D.legibles} fabricantes del Gran Área Metropolitana · Lectura 5 min</p>
      </header>
      <div class="tldr reveal">
        <p class="tldr-k">En resumen</p>
        <p>Analizamos <strong>{D.revisadas} fabricantes de cocinas y muebles a medida</strong> del GAM. Su Índice Optimiza promedio fue de <strong>{D.indice}/100</strong>: muestran bien el producto, pero el <strong>{D.sinPixel}% no tiene el píxel de Meta</strong> (solo {D.conPixel} de {D.revisadas}). Web bonita, cero medición.</p>
      </div>
      <div class="stats reveal">
        <div class="stat"><div class="sn">{D.sinPixel}<small>%</small></div><div class="sl">sin píxel de Meta</div></div>
        <div class="stat"><div class="sn">{D.sinAnalytics}<small>%</small></div><div class="sl">sin Google Analytics</div></div>
        <div class="stat"><div class="sn">{D.sinWhatsApp}<small>%</small></div><div class="sl">sin WhatsApp directo</div></div>
        <div class="stat"><div class="sn">{D.indice}<small>/100</small></div><div class="sl">Índice Optimiza (grado C)</div></div>
      </div>
      <div class="prose">
        <h2>Producto hermoso, web que no capta</h2>
        <p>Los fabricantes de cocinas y muebles a medida invierten en mostrar su trabajo: fotos, catálogos, showrooms. Pero su web termina siendo una galería, no una herramienta que capture y mida al interesado.</p>
        <div class="bars">
          {D.pilares.map((p) => (
            <div class="bar">
              <div class="bar-top"><span>{p.k}<em>{p.note}</em></span><span class="bar-v">{p.v}<small>/100</small></span></div>
              <div class="track"><span style={`width:${p.v}%;background:${p.v < 40 ? '#E24B4A' : p.v < 60 ? '#EF9F27' : 'var(--violet)'}`}></span></div>
            </div>
          ))}
        </div>
        <blockquote>De {D.revisadas} fabricantes, solo {D.conPixel} pueden volver a impactar a alguien que vio sus cocinas y no cotizó.</blockquote>
        <h2>El patrón del sector construcción</h2>
        <p>Este estudio es parte de nuestra serie de construcción. Junto a <a href="/analisis/estudio-webs-constructoras-costa-rica-2026/">constructoras</a>, <a href="/analisis/estudio-webs-acabados-instaladores-costa-rica-2026/">acabados</a> y <a href="/analisis/estudio-webs-piscinas-exteriores-costa-rica-2026/">piscinas</a>:</p>
        <div class="thesis">
          <div class="thesis-n">{D.secSinPixel}<small>%</small></div>
          <div class="thesis-t">de las <strong>{D.secTotal} empresas de construcción del GAM</strong> que analizamos <strong>no puede medir su web.</strong> <a href="/analisis/estudio-webs-sector-construccion-costa-rica-2026/" style="color:#E8956B">Ver el estudio del sector →</a></div>
        </div>
        <h2>Distribución por calificación</h2>
        <div class="dist">
          {D.grados.map((g) => (
            <div class="drow">
              <div class="dg">{g.g}<em>{g.label}</em></div>
              <div class="dtrack"><span class={g.cls} style={`width:${totalGrados ? (g.n / totalGrados) * 100 : 0}%`}></span></div>
              <div class="dn">{g.n}</div>
            </div>
          ))}
        </div>
        <h2>Metodología</h2>
        <ul>
          <li><strong>Muestra:</strong> {D.revisadas} fabricantes de cocinas y muebles a medida con dominio propio del GAM, de búsquedas públicas. No es muestreo aleatorio.</li>
          <li><strong>Herramienta:</strong> motor de diagnóstico de Optimiza (PageSpeed Insights API + análisis de HTML).</li>
          <li><strong>Métrica:</strong> Índice Optimiza (0–100): velocidad 30%, visibilidad 30%, conversión 20%, automatización 20%. Métrica propia.</li>
          <li><strong>Exclusiones:</strong> {D.excluidas} no pudieron leerse (bloqueo de bots o JavaScript).</li>
          <li><strong>Ética:</strong> no publicamos el nombre de ninguna empresa ni sus puntajes individuales.</li>
        </ul>
        <h2>Preguntas frecuentes</h2>
      </div>
      <div class="faq">
        {faqs.map((f) => (
          <div class="qa">
            <button class="q" aria-expanded="false">{f.q}<span class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d={plus} stroke="currentColor" stroke-width="2" stroke-linecap="round"></path></svg></span></button>
            <div class="a"><p>{f.a}</p></div>
          </div>
        ))}
      </div>
      <div class="art-cta dark">
        <p>¿Tu web muestra tu producto pero no mide nada? Descubrilo gratis en 30 segundos.</p>
        <div class="scanwrap"><Scanner /></div>
      </div>
    </div>
  </article>
</Base>
<style>
  .art { max-width: 760px; }
  .back { display: inline-flex; align-items: center; gap: 7px; font-family: var(--mono); font-size: 12.5px; letter-spacing: 0.04em; color: var(--muted); margin-bottom: 32px; transition: color .16s; }
  .back:hover { color: var(--violet-ink); }
  .art-head { margin-bottom: 30px; }
  .tag { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600; padding: 5px 10px; border-radius: 7px; display: inline-block; }
  .tag.res { color: var(--cyan-ink); background: rgba(14,150,176,0.12); }
  .art-head h1 { font-size: clamp(29px, 4.4vw, 44px); margin: 18px 0 0; }
  .art-meta { font-family: var(--mono); font-size: 12.5px; color: var(--faint); margin-top: 16px; }
  .tldr { background: var(--surface); border: 1px solid var(--line); border-left: 3px solid var(--violet); border-radius: 14px; padding: 22px 24px; margin-bottom: 28px; box-shadow: var(--card-shadow); }
  .tldr-k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--violet-ink); margin: 0 0 10px; font-weight: 700; }
  .tldr p:last-child { margin: 0; color: var(--text); font-size: 16.5px; line-height: 1.7; }
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 40px; }
  @media (max-width: 640px) { .stats { grid-template-columns: 1fr 1fr; } }
  .stat { background: #0B0A12; border-radius: 14px; padding: 20px 18px; }
  .stat .sn { font-family: var(--mono); font-size: 34px; font-weight: 700; color: var(--lime); letter-spacing: -0.03em; line-height: 1; }
  .stat .sn small { font-size: 16px; color: #9A95B3; }
  .stat .sl { font-size: 12.5px; color: #9A95B3; margin-top: 10px; line-height: 1.4; }
  .prose :global(h2) { font-family: var(--display); font-weight: 600; letter-spacing: -0.02em; font-size: clamp(22px, 3vw, 29px); margin: 44px 0 14px; }
  .prose :global(p) { color: var(--muted); font-size: 17px; line-height: 1.75; margin-bottom: 18px; }
  .prose :global(ul) { margin: 0 0 20px; padding-left: 22px; color: var(--muted); }
  .prose :global(li) { margin-bottom: 10px; line-height: 1.65; font-size: 16.5px; }
  .prose :global(strong) { color: var(--text); font-weight: 600; }
  .prose :global(a) { color: var(--violet-ink); text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(blockquote) { border-left: 3px solid var(--violet); padding: 4px 0 4px 20px; margin: 24px 0; color: var(--text); font-style: italic; font-size: 18px; line-height: 1.6; }
  .bars { display: flex; flex-direction: column; gap: 16px; margin: 26px 0 8px; }
  .bar-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 7px; }
  .bar-top span { font-size: 14.5px; color: var(--text); font-weight: 500; }
  .bar-top em { display: block; font-style: normal; font-size: 12px; color: var(--faint); font-weight: 400; margin-top: 2px; }
  .bar-v { font-family: var(--mono); font-weight: 700; color: var(--text); }
  .bar-v small { color: var(--faint); font-size: 12px; font-weight: 400; }
  .track { height: 9px; background: rgba(23,20,31,0.08); border-radius: 99px; overflow: hidden; }
  :global([data-theme="dark"]) .track { background: rgba(255,255,255,0.09); }
  .track span { display: block; height: 100%; border-radius: 99px; }
  .thesis { display: flex; align-items: center; gap: 22px; background: #0B0A12; border-radius: 16px; padding: 26px 28px; margin: 22px 0; }
  .thesis-n { font-family: var(--mono); font-size: 62px; font-weight: 700; color: var(--lime); letter-spacing: -0.04em; line-height: 1; flex: none; }
  .thesis-n small { font-size: 26px; }
  .thesis-t { color: #C9C4DE; font-size: 16px; line-height: 1.55; }
  .thesis-t strong { color: #fff; }
  @media (max-width: 520px) { .thesis { flex-direction: column; align-items: flex-start; gap: 10px; } }
  .dist { display: flex; flex-direction: column; gap: 10px; margin: 22px 0; }
  .drow { display: grid; grid-template-columns: 150px 1fr 28px; align-items: center; gap: 14px; }
  .dg { font-family: var(--mono); font-size: 15px; font-weight: 700; color: var(--text); }
  .dg em { display: block; font-style: normal; font-size: 11px; color: var(--faint); font-weight: 400; margin-top: 2px; letter-spacing: 0.02em; }
  .dtrack { height: 22px; background: rgba(23,20,31,0.05); border-radius: 7px; overflow: hidden; }
  :global([data-theme="dark"]) .dtrack { background: rgba(255,255,255,0.06); }
  .dtrack span { display: block; height: 100%; border-radius: 7px; min-width: 2px; }
  .dtrack .gA { background: #21B36B; } .dtrack .gB { background: #7FCf3F; }
  .dtrack .gC { background: #EF9F27; } .dtrack .gD { background: #E8743B; } .dtrack .gE { background: #E24B4A; }
  .dn { font-family: var(--mono); font-weight: 700; color: var(--text); text-align: right; }
  .faq { margin: 8px 0 0; }
  .qa { border-bottom: 1px solid var(--line); }
  .qa .q { width: 100%; background: none; border: none; text-align: left; display: flex; justify-content: space-between; align-items: center; gap: 16px; padding: 18px 0; font-family: var(--display); font-weight: 600; font-size: 17px; color: var(--text); cursor: pointer; }
  .qa .ic { flex: none; color: var(--violet-ink); transition: transform .2s; }
  .qa.open .ic { transform: rotate(45deg); }
  .qa .a { max-height: 0; overflow: hidden; transition: max-height .28s ease; }
  .qa .a p { color: var(--muted); font-size: 16px; line-height: 1.7; margin: 0 0 18px; }
  .art-cta { margin-top: 44px; padding-top: 32px; border-top: 1px solid var(--line); text-align: center; }
  .art-cta p { color: var(--text); font-size: 18px; font-weight: 500; margin-bottom: 18px; }
  .scanwrap { max-width: 560px; margin: 24px auto 0; text-align: left; }
</style>
