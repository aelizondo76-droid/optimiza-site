---
import Base from '../../layouts/Base.astro';
const D = {
  revisadas: 12, legibles: 12, excluidas: 0, indice: 41,
  pilares: [
    { k: 'Velocidad', v: 50, note: 'PageSpeed móvil (Lighthouse)' },
    { k: 'Visibilidad', v: 40, note: 'SEO y datos estructurados' },
    { k: 'Conversión', v: 40, note: 'CTA, reservas, conversión' },
    { k: 'Automatización', v: 30, note: 'Medición y retargeting' },
  ],
  sinPixel: 100, conPixel: 0, sinAnalytics: 100, sinWhatsApp: 100,
  grados: [
    { g: 'A', label: '≥ 80 · Excelente', n: 0, cls: 'gA' },
    { g: 'B', label: '70–79 · Bien', n: 0, cls: 'gB' },
    { g: 'C', label: '55–69 · Regular', n: 0, cls: 'gC' },
    { g: 'D', label: '40–54 · Deficiente', n: 12, cls: 'gD' },
    { g: 'E', label: '< 40 · Crítico', n: 0, cls: 'gE' },
  ],
  secTotal: 43, secSinPixel: 95,
};
const totalGrados = D.grados.reduce((s, x) => s + x.n, 0);
const publishDate = '2026-08-13';
const dateHuman = new Date(publishDate + 'T12:00:00').toLocaleDateString('es-CR', { year: 'numeric', month: 'long', day: 'numeric' });
const title = 'Restaurantes Costa Rica: 100% sin medición';
const description = 'Analizamos 12 restaurantes del GAM: TODOS índice 41/100, 100% sin píxel, 100% sin analytics, 100% sin WhatsApp, 100% reprueba velocidad. Sector en crisis digital.';
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og/estudio-restaurantes.png', Astro.site).href;
const faqs = [
  { q: '¿Qué tan malos son los restaurantes costarricenses en web?', a: 'Catastróficos. Índice Optimiza: 41/100 (grado D crítico). El 100% sin Meta Pixel, el 100% sin Google Analytics, el 100% sin WhatsApp directo, el 100% reprueba velocidad móvil. Es como ir a un restaurante sin certificado de higiene — nadie está midiendo, nadie está preparado, todo es caos.' },
  { q: '¿Cuál es el problema más grave?', a: 'TODO. Pero si hay que elegir uno: el 100% reprueba velocidad (carga >5s en móvil). Un cliente hambriento que abre tu web y tarda 5 segundos en cargar, se va a otro restaurante. Además, sin píxel, sin analytics, sin WhatsApp: estás ciega a cómo los clientes interactúan contigo.' },
  { q: '¿Hay algún restaurante que no sea un desastre digital?', a: 'No. De 12 restaurantes, todos tienen grado D. El mejor tiene índice 41/100. Es el sector más deficiente del estudio completo. Ni uno solo alcanzó grado C. Esto sugiere que los restaurantes ven la web como una "vitrina" opcional, no como un motor de negocio.' },
  { q: '¿Cómo es que TODOS tienen exactamente el mismo problema?', a: 'Porque los restaurantes fueron diseñados antes de la era digital. Sus webs son estáticas, hermosas en foto pero muertas en datos. Un sitio moderno tendría píxel, analytics, WhatsApp, reservas online. Los restaurantes tienen una foto bonita del plato y un teléfono. Es 1995 digitalmente.' },
  { q: '¿Qué es el Índice Optimiza?', a: 'Calificación 0-100: velocidad 30%, visibilidad 30%, conversión 20%, automatización 20%. Los restaurantes fallan en los 4: cargan lento, no aparecen en búsquedas, no permiten reservas online, no miden ni retargetn.' },
  { q: '¿Cómo se analizaron?', a: 'Se escanearon 12 restaurantes del GAM (Picnic, Bulalí, Franco, etc.) con el motor de diagnóstico de Optimiza en agosto de 2026. Todos resultaron críticos.' },
];
const articleLd = { '@context': 'https://schema.org', '@type': 'Report', headline: 'El estado de los restaurantes en línea en Costa Rica', description, image: ogImage, datePublished: publishDate, dateModified: publishDate, inLanguage: 'es-CR', author: { '@type': 'Organization', name: 'Optimiza', url: 'https://optimizahq.com' }, publisher: { '@type': 'Organization', name: 'Optimiza', url: 'https://optimizahq.com', logo: { '@type': 'ImageObject', url: 'https://optimizahq.com/favicon.svg' } }, mainEntityOfPage: canonical, keywords: ['restaurantes Costa Rica', 'web restaurante', 'reservas online', 'delivery', 'velocidad web'], about: { '@type': 'Thing', name: 'Restaurantes del GAM' } };
const datasetLd = { '@context': 'https://schema.org', '@type': 'Dataset', name: 'Diagnóstico web de restaurantes 2026', description: 'Índice Optimiza de 12 restaurantes del GAM.', creator: { '@type': 'Organization', name: 'Optimiza', url: 'https://optimizahq.com' }, temporalCoverage: '2026-08', spatialCoverage: { '@type': 'Place', name: 'Gran Área Metropolitana, Costa Rica' }, measurementTechnique: 'PageSpeed Insights API y análisis de HTML', variableMeasured: ['Velocidad', 'Visibilidad', 'Conversión', 'Automatización', 'Índice Optimiza'], isAccessibleForFree: true, url: canonical };
const faqLd = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const plus = 'M12 5v14M5 12h14';
---
<Base title={title} description={description} active="analisis">
  <Fragment slot="head">
    <meta property="og:image" content={ogImage} />
    <meta property="article:published_time" content={publishDate} />
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(datasetLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  </Fragment>
  <article class="section">
    <div class="wrap art">
      <a class="back" href="/analisis"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>Análisis y teardowns</a>
      <header class="art-head reveal">
        <span class="tag res">Investigación · Gastronomía</span>
        <h1>Restaurantes sin medir: el sector más ciego del GAM</h1>
        <p class="art-meta">{dateHuman} · Estudio de {D.legibles} restaurantes del Gran Área Metropolitana · Lectura 6 min</p>
      </header>
      <div class="tldr reveal">
        <p class="tldr-k">En resumen</p>
        <p>Analizamos <strong>{D.revisadas} restaurantes</strong> del GAM. Todos con grado D crítico. Índice Optimiza promedio: <strong>{D.indice}/100</strong> (el peor sector del estudio). El <strong>100% sin Meta Pixel</strong>, 100% sin Google Analytics, 100% sin WhatsApp directo. Todos reprueban velocidad. Es como ir a un restaurante sin certificado de higiene — nadie sabe qué está pasando.</p>
      </div>
      <div class="stats reveal">
        <div class="stat"><div class="sn">100<small>%</small></div><div class="sl">sin píxel de Meta</div></div>
        <div class="stat"><div class="sn">100<small>%</small></div><div class="sl">sin Google Analytics</div></div>
        <div class="stat"><div class="sn">100<small>%</small></div><div class="sl">reprueba velocidad</div></div>
        <div class="stat"><div class="sn">{D.indice}<small>/100</small></div><div class="sl">Índice Optimiza (grado D)</div></div>
      </div>
      <div class="prose">
        <h2>Webs hermosas, negocios ciegos</h2>
        <p>Los 12 restaurantes analizados tienen algo en común: todos tienen grado D (40-54/100). No es coincidencia. Es patrón sistémico. Las webs de restaurantes se diseñan como "vitrinas": bonitas fotos del plato, menú PDF, teléfono de contacto. Pero digitalmente están muertas.</p>
        <p>El 100% sin píxel significa: un cliente llega, ve el menú, se interesa, cierra la pestaña sin reservar. El restaurante nunca puede retargetarlo. El 100% sin analytics significa: no saben cuántos clientes los buscan en Google, no saben si el sitio genera conversiones, no saben cuál es el plato más fotografiado. El 100% sin WhatsApp significa: un cliente que quiere preguntar "¿todavía tienen mesa?", no puede. Tiene que llamar (si se acuerda del número).</p>
        <p>Es como ir a un restaurante sin certificado de higiene sanitaria. Nadie está controlando, nadie sabe qué está pasando, todo es caos operativo disfrazado de "tenemos web".</p>
        <div class="bars">
          {D.pilares.map((p) => (
            <div class="bar">
              <div class="bar-top"><span>{p.k}<em>{p.note}</em></span><span class="bar-v">{p.v}<small>/100</small></span></div>
              <div class="track"><span style={`width:${p.v}%;background:${p.v < 40 ? '#E24B4A' : p.v < 60 ? '#EF9F27' : 'var(--violet)'}`}></span></div>
            </div>
          ))}
        </div>
        <blockquote>Un restaurante que carga en 5 segundos pierde el 80% de los clientes que lo buscan en Google desde el móvil. El cliente hambriento no espera: abre, ve que carga lento, y abre TripAdvisor o Google Maps para buscar otra opción.</blockquote>
        <h2>La velocidad es supervivencia: 100% reprueba</h2>
        <p>No es una métrica académica: es dinero. En gastronomía, la decisión es rápida. "Busco dónde comer" → abre tu web → carga en 5+ segundos → se va a otro. En 100% de los restaurantes analizados, esto está pasando ahora mismo.</p>
        <p>Sin píxel, no pueden retargetar. Sin analytics, no saben qué está pasando. Sin WhatsApp, pierden contactos. Es triple ceguera: no ven, no miden, no comunican. Un cliente potencial llega, se va, y el restaurante nunca lo vuelve a ver.</p>
        <h2>Distribución por calificación: 12/12 grado D</h2>
        <div class="dist">
          {D.grados.map((g) => (
            <div class="drow">
              <div class="dg">{g.g}<em>{g.label}</em></div>
              <div class="dtrack"><span class={g.cls} style={`width:${totalGrados ? (g.n / totalGrados) * 100 : 0}%`}></span></div>
              <div class="dn">{g.n}</div>
            </div>
          ))}
        </div>
        <h2>¿Cómo sabe un restaurante si su web funciona?</h2>
        <p>Debería poder responder estas preguntas:</p>
        <ul>
          <li>¿Cuántas personas buscan mi restaurante en Google cada mes? (Sin Google Analytics, no sabe)</li>
          <li>¿De esos, cuántos hacen una reserva? (Sin píxel, no sabe)</li>
          <li>¿De los que se van sin reservar, cuántos vuelvo a retargetar? (Sin píxel, cero)</li>
          <li>¿Mi plato más buscado es X o Y? (Sin datos, no lo sabe)</li>
          <li>¿A qué hora recibo más búsquedas? (Sin analytics, adivinanza)</li>
        </ul>
        <p>Si no puede responder estas preguntas, su web no está sirviendo. Está siendo decoración digital.</p>
        <p><strong>Optimiza mide el suyo:</strong> nuestro sitio tiene píxel de Meta, Google Analytics conectado, CRM integrado. Cuando decimos "medición es crítica", lo practicamos. Los restaurantes deberían hacer lo mismo: primero mide tu propio negocio, luego optimízalo. Sin medir, estás conduciendo de noche sin faros.</p>
        <h2>Metodología</h2>
        <ul>
          <li><strong>Muestra:</strong> {D.revisadas} restaurantes del GAM con dominio propio (Picnic, Bulalí, Franco, etc.).</li>
          <li><strong>Herramienta:</strong> motor de diagnóstico de Optimiza (PageSpeed Insights API + análisis de HTML).</li>
          <li><strong>Métrica:</strong> Índice Optimiza (0–100): velocidad 30%, visibilidad 30%, conversión 20%, automatización 20%.</li>
          <li><strong>Exclusiones:</strong> {D.excluidas} no pudieron leerse.</li>
          <li><strong>Ética:</strong> no publicamos identidades ni puntajes individuales.</li>
        </ul>
        <h2>Preguntas frecuentes</h2>
      </div>
      <div class="faq">
        {faqs.map((f) => (
          <div class="qa">
            <button class="q" aria-expanded="false">{f.q}<span class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d={plus} stroke="currentColor" stroke-width="2" stroke-linecap="round"></path></svg></span></button>
            <div class="a"><p>{f.a}</p></div>
          </div>
        ))}
      </div>
      <div class="art-cta">
        <p>¿Tu restaurante mide su propia web?</p>
        <a class="btn btn-lime" href="/#top">Analizar mi sitio gratis</a>
      </div>
    </div>
  </article>
</Base>
<style>
  .art { max-width: 760px; }
  .back { display: inline-flex; align-items: center; gap: 7px; font-family: var(--mono); font-size: 12.5px; letter-spacing: 0.04em; color: var(--muted); margin-bottom: 32px; transition: color .16s; }
  .back:hover { color: var(--violet-ink); }
  .art-head { margin-bottom: 30px; }
  .tag { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600; padding: 5px 10px; border-radius: 7px; display: inline-block; }
  .tag.res { color: var(--cyan-ink); background: rgba(14,150,176,0.12); }
  .art-head h1 { font-size: clamp(29px, 4.4vw, 44px); margin: 18px 0 0; }
  .art-meta { font-family: var(--mono); font-size: 12.5px; color: var(--faint); margin-top: 16px; }
  .tldr { background: var(--surface); border: 1px solid var(--line); border-left: 3px solid var(--violet); border-radius: 14px; padding: 22px 24px; margin-bottom: 28px; box-shadow: var(--card-shadow); }
  .tldr-k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--violet-ink); margin: 0 0 10px; font-weight: 700; }
  .tldr p:last-child { margin: 0; color: var(--text); font-size: 16.5px; line-height: 1.7; }
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 40px; }
  @media (max-width: 640px) { .stats { grid-template-columns: 1fr 1fr; } }
  .stat { background: #0B0A12; border-radius: 14px; padding: 20px 18px; }
  .stat .sn { font-family: var(--mono); font-size: 34px; font-weight: 700; color: var(--lime); letter-spacing: -0.03em; line-height: 1; }
  .stat .sn small { font-size: 16px; color: #9A95B3; }
  .stat .sl { font-size: 12.5px; color: #9A95B3; margin-top: 10px; line-height: 1.4; }
  .prose :global(h2) { font-family: var(--display); font-weight: 600; letter-spacing: -0.02em; font-size: clamp(22px, 3vw, 29px); margin: 44px 0 14px; }
  .prose :global(p) { color: var(--muted); font-size: 17px; line-height: 1.75; margin-bottom: 18px; }
  .prose :global(ul) { margin: 0 0 20px; padding-left: 22px; color: var(--muted); }
  .prose :global(li) { margin-bottom: 10px; line-height: 1.65; font-size: 16.5px; }
  .prose :global(strong) { color: var(--text); font-weight: 600; }
  .prose :global(a) { color: var(--violet-ink); text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(blockquote) { border-left: 3px solid var(--violet); padding: 4px 0 4px 20px; margin: 24px 0; color: var(--text); font-style: italic; font-size: 18px; line-height: 1.6; }
  .bars { display: flex; flex-direction: column; gap: 16px; margin: 26px 0 8px; }
  .bar-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 7px; }
  .bar-top span { font-size: 14.5px; color: var(--text); font-weight: 500; }
  .bar-top em { display: block; font-style: normal; font-size: 12px; color: var(--faint); font-weight: 400; margin-top: 2px; }
  .bar-v { font-family: var(--mono); font-weight: 700; color: var(--text); }
  .bar-v small { color: var(--faint); font-size: 12px; font-weight: 400; }
  .track { height: 9px; background: rgba(23,20,31,0.08); border-radius: 99px; overflow: hidden; }
  :global([data-theme="dark"]) .track { background: rgba(255,255,255,0.09); }
  .track span { display: block; height: 100%; border-radius: 99px; }
  .dist { display: flex; flex-direction: column; gap: 10px; margin: 22px 0; }
  .drow { display: grid; grid-template-columns: 60px 1fr 40px; align-items: center; gap: 16px; }
  .dg { font-weight: 700; font-size: 18px; }
  .dg em { display: block; font-size: 11.5px; font-weight: 400; color: var(--faint); font-style: normal; margin-top: 2px; }
  .dtrack { height: 8px; background: rgba(23,20,31,0.08); border-radius: 99px; overflow: hidden; }
  :global([data-theme="dark"]) .dtrack { background: rgba(255,255,255,0.08); }
  .dtrack span { display: block; height: 100%; border-radius: 99px; }
  .dtrack .gA { background: #22C55E; }
  .dtrack .gB { background: #84CC16; }
  .dtrack .gC { background: #EF9F27; }
  .dtrack .gD { background: #F97316; }
  .dtrack .gE { background: #E24B4A; }
  .dn { text-align: right; font-weight: 600; font-size: 14px; color: var(--text); }
  .faq { margin: 32px 0 40px; }
  .qa { margin-bottom: 12px; }
  .q { width: 100%; text-align: left; background: var(--surface); border: 1px solid var(--line); border-radius: 10px; padding: 16px; cursor: pointer; font-size: 16px; font-weight: 500; color: var(--text); display: flex; justify-content: space-between; align-items: center; transition: all .2s; }
  .q:hover { background: var(--surface-hover); border-color: var(--violet); }
  .q[aria-expanded="true"] { background: var(--surface-hover); border-color: var(--violet); }
  .ic { display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; color: var(--violet); transition: transform .2s; }
  .q[aria-expanded="true"] .ic { transform: rotate(45deg); }
  .a { max-height: 0; overflow: hidden; transition: max-height .3s ease-out; }
  .q[aria-expanded="true"] ~ .a { max-height: 1000px; transition: max-height .3s ease-in; }
  .a p { margin: 0; padding: 16px 0 0; color: var(--muted); font-size: 15.5px; line-height: 1.7; }
  .art-cta { text-align: center; padding: 32px; background: var(--surface); border-radius: 16px; margin-top: 40px; }
  .art-cta p { color: var(--muted); margin: 0 0 16px; }
  .btn { display: inline-block; padding: 12px 28px; border-radius: 8px; font-weight: 600; text-decoration: none; transition: all .2s; }
  .btn-lime { background: var(--lime); color: #0B0A12; }
  .btn-lime:hover { transform: translateY(-2px); box-shadow: 0 12px 24px rgba(199,249,75,0.25); }
</style>
