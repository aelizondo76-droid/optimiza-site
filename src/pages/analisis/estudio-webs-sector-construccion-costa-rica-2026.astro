---
import Base from '../../layouts/Base.astro';
import Scanner from '../../components/Scanner.astro';
const D = {
  total: 90, legibles: 85, indice: 59,
  sinPixel: 93, sinAnalytics: 56, sinWhatsApp: 56, gradoA: 0,
  sectores: [
    { name: 'Acabados e instaladores', slug: 'estudio-webs-acabados-instaladores-costa-rica-2026', n: 18, indice: 61, sinPixel: 94, note: 'Buena visibilidad, pero lead-gen sin medir.' },
    { name: 'Cocinas y muebles a medida', slug: 'estudio-webs-cocinas-muebles-costa-rica-2026', n: 25, indice: 59, sinPixel: 88, note: 'Producto hermoso, web que no capta el lead.' },
    { name: 'Piscinas y exteriores', slug: 'estudio-webs-piscinas-exteriores-costa-rica-2026', n: 24, indice: 58, sinPixel: 95, note: 'Venden el sueño, sin medir el deseo.' },
    { name: 'Constructoras', slug: 'estudio-webs-constructoras-costa-rica-2026', n: 23, indice: 57, sinPixel: 96, note: 'Proyectos de millones, medición cero.' },
  ],
};
const publishDate = '2026-07-16';
const dateHuman = new Date(publishDate + 'T12:00:00').toLocaleDateString('es-CR', { year: 'numeric', month: 'long', day: 'numeric' });
const title = 'Webs del sector construcción en Costa Rica: 93% no mide';
const description = 'Analizamos 90 empresas de construcción del GAM —cocinas, constructoras, acabados y piscinas—. El 93% no puede medir su web. El estudio completo, por sub-nicho.';
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og/estudio-sector-construccion.png', Astro.site).href;
const faqs = [
  { q: '¿Cómo están las páginas web del sector construcción en Costa Rica?', a: 'Deficientes en medición. Analizamos 90 empresas de construcción del Gran Área Metropolitana (cocinas, constructoras, acabados y piscinas): el Índice Optimiza promedio fue de 59 sobre 100 y ninguna alcanzó el grado A. El 93% no tiene el píxel de Meta y el 56% no usa Google Analytics.' },
  { q: '¿Cuál es el problema más común de las empresas de construcción en su web?', a: 'La falta de medición. El 93% no puede medir ni recuperar a los prospectos que visitan su web, porque no tienen instaladas herramientas como el píxel de Meta o Google Analytics. Invierten en proyectos visuales sin saber qué genera cotizaciones.' },
  { q: '¿Qué sub-nicho de construcción tiene las mejores webs?', a: 'Los instaladores de acabados, con un Índice Optimiza promedio de 61 gracias a su buena visibilidad en Google. Le siguen cocinas y muebles (59), piscinas (58) y constructoras (57). Todos comparten el mismo vacío de medición.' },
  { q: '¿Qué es el Índice Optimiza?', a: 'Una calificación de 0 a 100 que resume la salud de un sitio web en cuatro pilares: velocidad (30%), visibilidad o SEO (30%), conversión (20%) y automatización o medición (20%). Se calcula con la API de PageSpeed Insights de Google más un análisis del HTML.' },
  { q: '¿Cómo se realizó el estudio del sector construcción?', a: 'Se analizaron 90 empresas de construcción con dominio propio del Gran Área Metropolitana en julio de 2026, en cuatro estudios independientes (cocinas y muebles, constructoras, acabados e instaladores, piscinas y exteriores), con el motor de diagnóstico de Optimiza: PageSpeed Insights API y análisis de HTML.' },
];
const reportLd = { '@context': 'https://schema.org', '@type': ['Report', 'Article'], headline: 'El estado de las webs del sector construcción en Costa Rica (2026)', description, image: ogImage, datePublished: publishDate, dateModified: publishDate, inLanguage: 'es-CR', author: { '@type': 'Organization', name: 'Optimiza', url: 'https://optimizahq.com' }, publisher: { '@type': 'Organization', name: 'Optimiza', url: 'https://optimizahq.com', logo: { '@type': 'ImageObject', url: 'https://optimizahq.com/favicon.svg' } }, mainEntityOfPage: canonical, keywords: ['sector construcción Costa Rica', 'marketing construcción', 'web para constructoras', 'remodelación', 'cocinas a medida', 'Meta Pixel', 'Gran Área Metropolitana'], about: { '@type': 'Thing', name: 'Páginas web de empresas de construcción y remodelación en Costa Rica' } };
const faqLd = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const plus = 'M12 5v14M5 12h14';
const maxN = Math.max(...D.sectores.map((s) => s.indice));
---
<Base
  title={title}
  description={description}
  active="analisis"
  ogImage={ogImage}
  breadcrumbs={[{ name: 'Análisis', url: 'https://optimizahq.com/analisis/' }, { name: title, url: canonical }]}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={publishDate} />
    <script type="application/ld+json" set:html={JSON.stringify(reportLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
    <script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', '@type': 'Dataset', name: 'Diagnóstico web del sector construcción del GAM 2026', description: `Puntajes del Índice Optimiza (velocidad, visibilidad, conversión y automatización) de ${D.legibles} empresas de construcción del Gran Área Metropolitana de Costa Rica.`, creator: { '@type': 'Organization', name: 'Optimiza', url: 'https://optimizahq.com' }, temporalCoverage: '2026', spatialCoverage: { '@type': 'Place', name: 'Gran Área Metropolitana, Costa Rica' }, measurementTechnique: 'PageSpeed Insights API (Lighthouse) y análisis de HTML', variableMeasured: ['Velocidad', 'Visibilidad (SEO)', 'Conversión', 'Automatización', 'Índice Optimiza'], isAccessibleForFree: true, license: 'https://optimizahq.com/legal/licencia-datos/', datePublished: publishDate, dateModified: publishDate, url: canonical })} />
  </Fragment>
  <article class="section">
    <div class="wrap art">
      <a class="back" href="/analisis"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>Análisis y teardowns</a>
      <header class="art-head reveal">
        <span class="tag res">Investigación · Construcción</span>
        <h1>El estado de las webs del sector construcción en Costa Rica</h1>
        <p class="art-meta">{dateHuman} · {D.total} empresas · 4 sub-nichos · Gran Área Metropolitana</p>
      </header>
      <div class="tldr reveal">
        <p class="tldr-k">En resumen</p>
        <p>Analizamos <strong>{D.total} empresas de construcción</strong> del Gran Área Metropolitana en cuatro sub-nichos —cocinas y muebles, constructoras, acabados y piscinas—. El Índice Optimiza promedio fue de <strong>{D.indice}/100</strong> y ninguna alcanzó el grado A. El hallazgo es transversal: <strong>el {D.sinPixel}% no puede medir su web</strong> (sin píxel de Meta) y el {D.sinAnalytics}% no usa Google Analytics.</p>
      </div>
      <div class="stats reveal">
        <div class="stat"><div class="sn">{D.total}</div><div class="sl">empresas de construcción analizadas</div></div>
        <div class="stat"><div class="sn">{D.sinPixel}<small>%</small></div><div class="sl">sin píxel de Meta (no miden ni recuperan)</div></div>
        <div class="stat"><div class="sn">{D.sinAnalytics}<small>%</small></div><div class="sl">sin Google Analytics</div></div>
        <div class="stat"><div class="sn">{D.gradoA}<small>/{D.total}</small></div><div class="sl">alcanzó el grado A</div></div>
      </div>
      <div class="prose">
        <h2>Un punto ciego que atraviesa el sector</h2>
        <p>Cocinas, constructoras, acabados, piscinas: negocios distintos, todos de alto ticket, todos dependientes de referencias y proyectos visuales. Y todos con el mismo vacío: <strong>casi ninguno mide lo que pasa en su web.</strong></p>
        <p>Sin el <a href="/analisis/glosario-digital-empresas#pixel">píxel</a> de Meta ni Google <a href="/analisis/glosario-digital-empresas#analitycs">Analytics</a>, una empresa de construcción no puede volver a impactar a quien vio sus proyectos, no sabe qué canal trae cotizaciones reales y no distingue la publicidad que funciona de la que solo gasta.</p>
      </div>
      <h2 class="sec-h">El sector, por dentro</h2>
      <div class="cmp">
        {D.sectores.map((s) => (
          <div class="cmp-row">
            <div class="cmp-name">{s.name}<em>{s.n} empresas</em></div>
            <div class="cmp-bar"><div class="track"><span style={`width:${(s.indice / maxN) * 100}%`}></span></div><b>{s.indice}<small>/100</small></b></div>
            <div class="cmp-pix">{s.sinPixel}%<em>sin píxel</em></div>
          </div>
        ))}
      </div>
      <div class="sectors">
        {D.sectores.map((s) => (
          <a class="sec-card" href={`/analisis/${s.slug}`}>
            <div class="sc-top"><span class="sc-idx">{s.indice}<small>/100</small></span><span class="sc-pix">{s.sinPixel}% sin píxel</span></div>
            <h3>{s.name}</h3>
            <p>{s.note}</p>
            <span class="sc-link">Ver el estudio →</span>
          </a>
        ))}
      </div>
      <div class="prose">
        <h2>Lo que significa para una empresa</h2>
        <p>Cuando un sector entero comparte la misma debilidad, deja de ser un problema y se vuelve una <strong>oportunidad</strong>. La medición es la base para gastar mejor en publicidad y recuperar prospectos que ya mostraron interés en un proyecto.</p>
        <blockquote>En un sector donde nadie mide, el primero que lo haga no compite mejor: juega otro juego.</blockquote>
        <h2>Metodología</h2>
        <ul>
          <li><strong>Muestra:</strong> {D.total} empresas de construcción con dominio propio del GAM, en cuatro estudios: <a href="/analisis/estudio-webs-cocinas-muebles-costa-rica-2026">cocinas y muebles</a> (25), <a href="/analisis/estudio-webs-constructoras-costa-rica-2026">constructoras</a> (23), <a href="/analisis/estudio-webs-acabados-instaladores-costa-rica-2026">acabados</a> (18) y <a href="/analisis/estudio-webs-piscinas-exteriores-costa-rica-2026">piscinas</a> (24). No es muestreo aleatorio.</li>
          <li><strong>Herramienta:</strong> motor de diagnóstico de Optimiza (PageSpeed Insights API + análisis de HTML). De las {D.total} empresas, {D.legibles} arrojaron datos completos.</li>
          <li><strong>Métrica:</strong> Índice Optimiza (0–100): velocidad 30%, visibilidad 30%, conversión 20%, automatización 20%. Métrica propia, no oficial de Google.</li>
          <li><strong>Ética:</strong> no publicamos el nombre de ninguna empresa ni sus puntajes individuales.</li>
        </ul>
        <h2>Preguntas frecuentes</h2>
      </div>
      <div class="faq">
        {faqs.map((f) => (
          <div class="qa">
            <button class="q" aria-expanded="false">{f.q}<span class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d={plus} stroke="currentColor" stroke-width="2" stroke-linecap="round"></path></svg></span></button>
            <div class="a"><p>{f.a}</p></div>
          </div>
        ))}
      </div>
      <div class="art-cta dark">
        <p>¿Tu empresa está en el 93% que no mide? Descubrilo gratis en 30 segundos.</p>
        <div class="scanwrap"><Scanner /></div>
      </div>
    </div>
  </article>
</Base>
<style>
  .art { max-width: 780px; }
  .back { display: inline-flex; align-items: center; gap: 7px; font-family: var(--mono); font-size: 12.5px; letter-spacing: 0.04em; color: var(--muted); margin-bottom: 32px; transition: color .16s; }
  .back:hover { color: var(--violet-ink); }
  .art-head { margin-bottom: 30px; }
  .tag { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600; padding: 5px 10px; border-radius: 7px; display: inline-block; }
  .tag.res { color: var(--cyan-ink); background: rgba(14,150,176,0.12); }
  .art-head h1 { font-size: clamp(30px, 4.6vw, 46px); margin: 18px 0 0; }
  .art-meta { font-family: var(--mono); font-size: 12.5px; color: var(--faint); margin-top: 16px; }
  .tldr { background: var(--surface); border: 1px solid var(--line); border-left: 3px solid var(--violet); border-radius: 14px; padding: 22px 24px; margin-bottom: 28px; box-shadow: var(--card-shadow); }
  .tldr-k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--violet-ink); margin: 0 0 10px; font-weight: 700; }
  .tldr p:last-child { margin: 0; color: var(--text); font-size: 16.5px; line-height: 1.7; }
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }
  @media (max-width: 640px) { .stats { grid-template-columns: 1fr 1fr; } }
  .stat { background: #0B0A12; border-radius: 14px; padding: 20px 18px; }
  .stat .sn { font-family: var(--mono); font-size: 34px; font-weight: 700; color: var(--lime); letter-spacing: -0.03em; line-height: 1; }
  .stat .sn small { font-size: 16px; color: #9A95B3; }
  .stat .sl { font-size: 12.5px; color: #9A95B3; margin-top: 10px; line-height: 1.4; }
  .prose :global(h2), .sec-h { font-family: var(--display); font-weight: 600; letter-spacing: -0.02em; font-size: clamp(22px, 3vw, 29px); margin: 44px 0 14px; color: var(--text); }
  .prose :global(p) { color: var(--muted); font-size: 17px; line-height: 1.75; margin-bottom: 18px; }
  .prose :global(ul) { margin: 0 0 20px; padding-left: 22px; color: var(--muted); }
  .prose :global(li) { margin-bottom: 10px; line-height: 1.65; font-size: 16.5px; }
  .prose :global(strong) { color: var(--text); font-weight: 600; }
  .prose :global(a) { color: var(--violet-ink); text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(blockquote) { border-left: 3px solid var(--violet); padding: 4px 0 4px 20px; margin: 24px 0; color: var(--text); font-style: italic; font-size: 18px; line-height: 1.6; }
  .cmp { display: flex; flex-direction: column; gap: 14px; margin: 8px 0 28px; }
  .cmp-row { display: grid; grid-template-columns: 210px 1fr 92px; align-items: center; gap: 16px; }
  @media (max-width: 560px) { .cmp-row { grid-template-columns: 1fr auto; } .cmp-bar { display: none; } }
  .cmp-name { font-size: 15px; color: var(--text); font-weight: 500; }
  .cmp-name em { display: block; font-style: normal; font-size: 12px; color: var(--faint); margin-top: 2px; }
  .cmp-bar { display: flex; align-items: center; gap: 12px; }
  .cmp-bar .track { flex: 1; height: 9px; background: rgba(23,20,31,0.08); border-radius: 99px; overflow: hidden; }
  :global([data-theme="dark"]) .cmp-bar .track { background: rgba(255,255,255,0.09); }
  .cmp-bar .track span { display: block; height: 100%; background: var(--violet); border-radius: 99px; }
  .cmp-bar b { font-family: var(--mono); color: var(--text); font-size: 15px; }
  .cmp-bar b small { color: var(--faint); font-size: 11px; }
  .cmp-pix { text-align: right; font-family: var(--mono); font-weight: 700; color: var(--lime); font-size: 20px; }
  .cmp-pix em { display: block; font-style: normal; font-size: 10.5px; color: var(--faint); font-weight: 400; letter-spacing: 0.04em; }
  .sectors { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin: 8px 0 12px; }
  @media (max-width: 680px) { .sectors { grid-template-columns: 1fr; } }
  .sec-card { display: flex; flex-direction: column; background: var(--surface); border: 1px solid var(--line-soft); border-radius: 16px; padding: 20px; box-shadow: var(--card-shadow); transition: border-color .2s, transform .2s; }
  .sec-card:hover { border-color: var(--violet); transform: translateY(-3px); }
  .sc-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 12px; }
  .sc-idx { font-family: var(--mono); font-weight: 700; font-size: 24px; color: var(--text); }
  .sc-idx small { font-size: 12px; color: var(--faint); }
  .sc-pix { font-family: var(--mono); font-size: 11.5px; color: var(--violet-ink); font-weight: 600; }
  .sec-card h3 { font-size: 17px; margin: 0 0 8px; }
  .sec-card p { color: var(--muted); font-size: 13.5px; line-height: 1.5; margin: 0 0 16px; }
  .sc-link { margin-top: auto; font-family: var(--mono); font-size: 12px; color: var(--violet-ink); font-weight: 600; }
  .faq { margin: 8px 0 0; }
  .qa { border-bottom: 1px solid var(--line); }
  .qa .q { width: 100%; background: none; border: none; text-align: left; display: flex; justify-content: space-between; align-items: center; gap: 16px; padding: 18px 0; font-family: var(--display); font-weight: 600; font-size: 17px; color: var(--text); cursor: pointer; }
  .qa .ic { flex: none; color: var(--violet-ink); transition: transform .2s; }
  .qa.open .ic { transform: rotate(45deg); }
  .qa .a { max-height: 0; overflow: hidden; transition: max-height .28s ease; }
  .qa .a p { color: var(--muted); font-size: 16px; line-height: 1.7; margin: 0 0 18px; }
  .art-cta { margin-top: 44px; padding-top: 32px; border-top: 1px solid var(--line); text-align: center; }
  .art-cta p { color: var(--text); font-size: 18px; font-weight: 500; margin-bottom: 18px; }
  .scanwrap { max-width: 560px; margin: 24px auto 0; text-align: left; }
</style>
