---
import Base from '../layouts/Base.astro';
import Scanner from '../components/Scanner.astro';
import { getSeo } from '../lib/seo';
const seo = await getSeo('analisis', {
  title: 'Análisis y Teardowns — Optimiza',
  description: 'Auditamos sitios en público, publicamos datos propios y mostramos el antes/después de cada optimización. Así ves cómo trabajamos antes de contratarnos.',
});
const title = seo.title;
const description = seo.description;
const arrow = 'M5 12h14M13 6l6 6-6 6';
const check = 'M5 12 l5 5 9-11';
import { getAnalisis, categoryMeta } from '../lib/content';
const posts = await getAnalisis();
---
<Base title={title} description={description} active="analisis">
  <section class="hero section">
    <div class="wrap">
      <div>
        <p class="eyebrow">Análisis y teardowns</p>
        <h1>No prometemos resultados. Los <em>mostramos</em>.</h1>
        <p class="lead">Auditamos sitios reales —incluido el nuestro— en público, publicamos datos propios y enseñamos el antes/después de cada optimización. Así ves cómo trabajamos antes de contratarnos.</p>
        <div class="hero-cta">
          <a class="btn btn-violet" href="#final">Analiza tu web gratis</a>
          <a class="btn btn-ghost" href="#investigacion">Ver la investigación</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="wrap">
      <div class="feature reveal">
        <div class="fc-body">
          <span class="tag tear">Teardown destacado</span>
          <h2>Tienda de moda online: 5 fugas que drenaban sus ventas cada día.</h2>
          <p class="fc-desc">Un e-commerce con buen producto y buen tráfico, perdiendo compradores por problemas invisibles. Desglosamos qué encontramos y qué cambiaría el resultado.</p>
          <ul class="finds">
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" x2="12" y1="8" y2="12"></line><line x1="12" x2="12.01" y1="16" y2="16"></line></svg>Imágenes de producto de 4 MB sin comprimir</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" x2="12" y1="8" y2="12"></line><line x1="12" x2="12.01" y1="16" y2="16"></line></svg>Sin medición de conversión (GA4 mal configurado)</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" x2="12" y1="8" y2="12"></line><line x1="12" x2="12.01" y1="16" y2="16"></line></svg>Checkout de 6 pasos que espantaba compras</li>
          </ul>
          <a class="fc-link" href="#final">Leer el análisis completo →</a>
        </div>
        <div class="fc-viz">
          <div class="jump">
            <div class="j"><div class="jn bad">34</div><div class="jl">Antes</div></div>
            <div class="jarrow"><svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d={arrow} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg></div>
            <div class="j"><div class="jn good">92</div><div class="jl">Después</div></div>
            <div class="jl" style="align-self:flex-end;margin-left:6px">PageSpeed</div>
          </div>
          <div class="barline"><div class="bl-top"><span>Carga móvil · antes</span><span>6.1s</span></div><div class="track"><span style="width:90%;background:#E24B4A"></span></div></div>
          <div class="barline"><div class="bl-top"><span>Carga móvil · después</span><span>1.2s</span></div><div class="track"><span style="width:20%;background:#C7F94B"></span></div></div>
          <div class="fc-metric">Proyección de conversión: <b>+31%</b> con el mismo tráfico</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="wrap">
      <div class="ahead reveal">
        <div><p class="eyebrow">La biblioteca</p><h2>Análisis, teardowns e investigación.</h2></div>
        <a class="btn btn-ghost" href="#final">Pedir el análisis de tu web</a>
      </div>
      <div class="an-grid">
        {posts.map((p) => {
          const cat = categoryMeta[p.entry.category] ?? categoryMeta.teardown;
          return (
            <article class="an-card reveal">
              <span class={`tag ${cat.cls}`}>{cat.label}</span>
              <h3>{p.entry.title}</h3>
              <p class="ac-desc">{p.entry.excerpt}</p>
              <a class="ac-link" href={`/analisis/${p.slug}`}>Leer análisis →</a>
            </article>
          );
        })}
        {posts.length === 0 && (
          <p class="an-empty">Muy pronto publicaremos nuestros primeros análisis. Mientras tanto, <a href="#final">pide el diagnóstico de tu web</a>.</p>
        )}
      </div>
    </div>
  </section>

  <section class="section" id="investigacion-maestra">
    <div class="wrap">
      <div class="band dark reveal" style="border: 2px solid var(--lime);">
        <div class="tband">
          <div class="thead">
            <span class="tag res" style="background: rgba(199, 249, 75, 0.2); color: var(--lime);">Investigación maestra</span>
            <h2>La crisis invisible: estado digital de empresas en Costa Rica 2026</h2>
            <p class="lead">Análisis riguroso de 386 sitios web en 4 sectores. 88% sin Meta Pixel. Crisis sistémica de medición digital que cuesta ~$122 millones anuales en oportunidades perdidas. La radiografía completa del estado actual.</p>
          </div>
          <div class="rstats">
            <div class="rstat"><div class="rn">386</div><div class="rl">sitios analizados</div></div>
            <div class="rstat"><div class="rn">88<small>%</small></div><div class="rl">sin píxel de Meta</div></div>
            <div class="rstat"><div class="rn">4</div><div class="rl">sectores estudiados</div></div>
            <div class="rstat"><div class="rn">58<small>/100</small></div><div class="rl">índice Optimiza promedio</div></div>
          </div>
          <div class="rcta">
            <a class="btn btn-lime" href="/analisis/estado-digital-empresas-costa-rica-2026">Leer investigación completa (2000+ palabras)</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="investigacion">
    <div class="wrap">
      <div class="band dark reveal">
        <div class="tband">
          <div class="thead">
            <p class="eyebrow">Investigación propia</p>
            <h2>Analizamos 104 clínicas de salud del GAM. El 94% vuela a ciegas.</h2>
            <p class="lead">Datos originales, no opiniones. Radiografiamos las webs de clínicas dentales, estéticas y consultorios médicos del Gran Área Metropolitana con nuestro motor de diagnóstico. El hallazgo transversal: casi ninguna puede medir ni recuperar a los pacientes que las visitan.</p>
          </div>
          <div class="rstats">
            <div class="rstat"><div class="rn">94<small>%</small></div><div class="rl">sin píxel de Meta (sin retargeting)</div></div>
            <div class="rstat"><div class="rn">104</div><div class="rl">clínicas de salud analizadas</div></div>
            <div class="rstat"><div class="rn">3</div><div class="rl">sectores: dental · estética · médicos</div></div>
            <div class="rstat"><div class="rn">1<small>/104</small></div><div class="rl">alcanzó el grado A</div></div>
          </div>
          <div class="rcta">
            <a class="btn btn-lime" href="/analisis/estudio-webs-sector-salud-costa-rica-2026">Ver el estudio del sector salud</a>
          </div>
          <p class="rsub">Por sector: <a href="/analisis/estudio-webs-clinicas-dentales-costa-rica-2026">dentales</a> · <a href="/analisis/estudio-webs-clinicas-esteticas-costa-rica-2026">medicina estética</a> · <a href="/analisis/estudio-webs-consultorios-medicos-costa-rica-2026">consultorios médicos</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="investigacion-construccion" style="padding-top:0">
    <div class="wrap">
      <div class="band dark reveal">
        <div class="tband">
          <div class="thead">
            <p class="eyebrow">Investigación propia</p>
            <h2>Analizamos 90 empresas de construcción del GAM. El 93% no mide su web.</h2>
            <p class="lead">Cocinas y muebles a medida, constructoras, acabados e instaladores, piscinas y exteriores. Cambia el sub-nicho; el punto ciego es el mismo: casi nadie puede medir ni recuperar a los prospectos que visitan su web.</p>
          </div>
          <div class="rstats">
            <div class="rstat"><div class="rn">93<small>%</small></div><div class="rl">sin píxel de Meta (sin retargeting)</div></div>
            <div class="rstat"><div class="rn">90</div><div class="rl">empresas de construcción analizadas</div></div>
            <div class="rstat"><div class="rn">4</div><div class="rl">sub-nichos del sector</div></div>
            <div class="rstat"><div class="rn">0</div><div class="rl">alcanzaron el grado A</div></div>
          </div>
          <div class="rcta">
            <a class="btn btn-lime" href="/analisis/estudio-webs-sector-construccion-costa-rica-2026">Ver el estudio del sector construcción</a>
          </div>
          <p class="rsub">Por sub-nicho: <a href="/analisis/estudio-webs-cocinas-muebles-costa-rica-2026">cocinas y muebles</a> · <a href="/analisis/estudio-webs-constructoras-costa-rica-2026">constructoras</a> · <a href="/analisis/estudio-webs-acabados-instaladores-costa-rica-2026">acabados</a> · <a href="/analisis/estudio-webs-piscinas-exteriores-costa-rica-2026">piscinas</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="investigacion-ecommerce" style="padding-top:0">
    <div class="wrap">
      <div class="band dark reveal">
        <div class="tband">
          <div class="thead">
            <p class="eyebrow">Investigación propia</p>
            <h2>Analizamos 109 tiendas en línea del GAM. El 82% no mide su web.</h2>
            <p class="lead">Moda, belleza, hogar, electrónica, alimentos, mascotas. E-commerce enfrenta un triple reto: velocidad crítica, medición ausente y conversión baja. Sin el píxel de Meta, pierden carritos abandonados y no pueden retargetar.</p>
          </div>
          <div class="rstats">
            <div class="rstat"><div class="rn">82<small>%</small></div><div class="rl">sin píxel de Meta</div></div>
            <div class="rstat"><div class="rn">109</div><div class="rl">tiendas analizadas</div></div>
            <div class="rstat"><div class="rn">6</div><div class="rl">sub-nichos de e-commerce</div></div>
            <div class="rstat"><div class="rn">3</div><div class="rl">alcanzaron el grado A</div></div>
          </div>
          <div class="rcta">
            <a class="btn btn-lime" href="/analisis/estudio-webs-ecommerce-costa-rica-2026">Ver el estudio del e-commerce</a>
          </div>
          <p class="rsub">Por sub-nicho: <a href="/analisis/estudio-webs-tienda-moda-costa-rica-2026">moda</a> · <a href="/analisis/estudio-webs-tienda-belleza-costa-rica-2026">belleza</a> · <a href="/analisis/estudio-webs-tienda-hogar-costa-rica-2026">hogar</a> · <a href="/analisis/estudio-webs-tienda-electronica-costa-rica-2026">electrónica</a> · <a href="/analisis/estudio-webs-tienda-alimentos-costa-rica-2026">alimentos</a> · <a href="/analisis/estudio-webs-tienda-mascotas-costa-rica-2026">mascotas</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="investigacion-servicios" style="padding-top:0">
    <div class="wrap">
      <div class="band dark reveal">
        <div class="tband">
          <div class="thead">
            <p class="eyebrow">Investigación propia</p>
            <h2>Analizamos 40 empresas de servicios digitales del GAM. El 87% no mide su web.</h2>
            <p class="lead">Agencias web, marketing digital, programación, educación y consultoría. El sector que más vende soluciones digitales, es el que menos las implementa en su propio negocio. Hipocresía sistémica: venden píxel de Meta, pero el 87% no lo tiene.</p>
          </div>
          <div class="rstats">
            <div class="rstat"><div class="rn">87<small>%</small></div><div class="rl">sin píxel de Meta</div></div>
            <div class="rstat"><div class="rn">40</div><div class="rl">empresas de servicios digitales</div></div>
            <div class="rstat"><div class="rn">5</div><div class="rl">sub-nichos analizados</div></div>
            <div class="rstat"><div class="rn">1</div><div class="rl">alcanzó el grado A</div></div>
          </div>
          <div class="rcta">
            <a class="btn btn-lime" href="/analisis/estudio-webs-servicios-digitales-costa-rica-2026">Ver el estudio de servicios digitales</a>
          </div>
          <p class="rsub">Por sub-nicho: <a href="/analisis/estudio-webs-agencias-diseño-costa-rica-2026">agencias web</a> · <a href="/analisis/estudio-webs-marketing-digital-costa-rica-2026">marketing digital</a> · <a href="/analisis/estudio-webs-programacion-desarrollo-costa-rica-2026">programación</a> · <a href="/analisis/estudio-webs-academias-cursos-costa-rica-2026">cursos online</a> · <a href="/analisis/estudio-webs-consultoria-empresarial-costa-rica-2026">consultoría</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="investigacion-alimentos" style="padding-top:0">
    <div class="wrap">
      <div class="band dark reveal">
        <div class="tband">
          <div class="thead">
            <p class="eyebrow">Investigación propia</p>
            <h2>Analizamos 43 negocios de gastronomía del GAM. El 95% no mide su web.</h2>
            <p class="lead">Restaurantes, cafeterías, panaderías, heladerías, bares. El sector gastronómico hace productos excelentes pero opera digitalmente en la oscuridad. Sin píxel, sin retargeting, sin data. Vende comida pero no sabe quién compra.</p>
          </div>
          <div class="rstats">
            <div class="rstat"><div class="rn">95<small>%</small></div><div class="rl">sin píxel de Meta</div></div>
            <div class="rstat"><div class="rn">43</div><div class="rl">negocios de gastronomía</div></div>
            <div class="rstat"><div class="rn">5</div><div class="rl">sub-nichos analizados</div></div>
            <div class="rstat"><div class="rn">0</div><div class="rl">alcanzaron el grado A</div></div>
          </div>
          <div class="rcta">
            <a class="btn btn-lime" href="/analisis/estudio-webs-alimentos-bebidas-costa-rica-2026">Ver el estudio de alimentos y bebidas</a>
          </div>
          <p class="rsub">Por sub-nicho: <a href="/analisis/estudio-webs-restaurantes-costa-rica-2026">restaurantes</a> · <a href="/analisis/estudio-webs-cafeterias-costa-rica-2026">cafeterías</a> · <a href="/analisis/estudio-webs-panaderias-costa-rica-2026">panaderías</a> · <a href="/analisis/estudio-webs-heladerias-costa-rica-2026">heladerías</a> · <a href="/analisis/estudio-webs-bares-discotecas-costa-rica-2026">bares</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section final dark" id="final">
    <div class="fglow"></div>
    <div class="wrap">
      <p class="eyebrow" style="justify-content:center">Tu análisis, gratis</p>
      <h2>Tu web merece su propio teardown.</h2>
      <p class="lead" style="margin:18px auto 22px">Nuestro escáner es tu primer análisis — en segundos, sobre tu sitio. Sin registro para empezar.</p>
      <div class="scanwrap"><Scanner /></div>
    </div>
  </section>
</Base>

<style>
  .hero h1 { font-size: clamp(36px, 5.4vw, 60px); max-width: 15ch; }
  .hero h1 em { font-style: normal; color: var(--violet-ink); }
  .hero .lead { margin-top: 20px; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px; }

  .tag { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600; padding: 5px 10px; border-radius: 7px; display: inline-block; }
  .tag.tear { color: var(--violet-ink); background: color-mix(in srgb, var(--violet) 12%, transparent); }
  .tag.res { color: var(--cyan-ink); background: rgba(14,150,176,0.12); }
  .tag.self { color: #4A5A10; background: rgba(199,249,75,0.30); }
  .tag.conv { color: #8a4b12; background: rgba(239,159,39,0.16); }

  .feature { background: var(--surface); border: 1px solid var(--line); border-radius: 20px; box-shadow: var(--card-shadow); overflow: hidden; display: grid; grid-template-columns: 1.15fr 0.85fr; }
  @media (max-width: 820px) { .feature { grid-template-columns: 1fr; } }
  .fc-body { padding: clamp(24px, 3.5vw, 40px); }
  .feature h2 { font-size: clamp(24px, 3vw, 32px); margin: 16px 0 0; }
  .fc-desc { color: var(--muted); font-size: 15.5px; margin-top: 14px; line-height: 1.6; }
  .finds { list-style: none; margin: 22px 0 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .finds li { display: flex; gap: 10px; align-items: flex-start; font-size: 14px; color: var(--text); }
  .finds li svg { color: #E24B4A; flex: none; margin-top: 3px; }
  .fc-link { margin-top: 24px; display: inline-block; font-family: var(--mono); font-size: 13px; color: var(--violet-ink); font-weight: 600; }
  .fc-viz { background: #0B0A12; padding: clamp(24px, 3.5vw, 36px); display: flex; flex-direction: column; justify-content: center; gap: 20px; }
  .jump { display: flex; align-items: center; gap: 16px; }
  .jump .j { text-align: center; }
  .jump .jn { font-family: var(--mono); font-size: 40px; font-weight: 700; letter-spacing: -0.03em; line-height: 1; }
  .jump .jn.bad { color: #E24B4A; } .jump .jn.good { color: #C7F94B; }
  .jump .jl { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: #6A6580; margin-top: 6px; }
  .jump .jarrow { color: #E8956B; }
  .barline .bl-top { display: flex; justify-content: space-between; font-family: var(--mono); font-size: 11.5px; margin-bottom: 6px; color: #9A95B3; }
  .track { height: 8px; background: rgba(255,255,255,0.09); border-radius: 99px; overflow: hidden; }
  .track span { display: block; height: 100%; border-radius: 99px; }
  .fc-metric { font-family: var(--mono); font-size: 12px; color: #9A95B3; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; }
  .fc-metric b { color: #C7F94B; }

  .ahead { display: flex; justify-content: space-between; align-items: flex-end; gap: 20px; margin-bottom: 32px; flex-wrap: wrap; }
  .ahead h2 { font-size: clamp(24px, 3.4vw, 34px); }
  .an-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  @media (max-width: 820px) { .an-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .an-grid { grid-template-columns: 1fr; } }
  .an-card { background: var(--surface); border: 1px solid var(--line-soft); border-radius: 16px; padding: 22px; box-shadow: var(--card-shadow); display: flex; flex-direction: column; align-items: flex-start; transition: border-color .2s, transform .2s; }
  .an-card:hover { border-color: var(--violet); transform: translateY(-3px); }
  .an-card h3 { font-size: 17px; margin: 14px 0 0; line-height: 1.25; }
  .an-card .ac-metric { margin-top: 14px; font-family: var(--mono); font-size: 13px; color: var(--text); }
  .an-card .ac-desc { margin-top: 12px; font-size: 13.5px; color: var(--muted); line-height: 1.5; }
  .an-empty { color: var(--muted); font-size: 15px; grid-column: 1 / -1; }
  .an-empty a { color: var(--violet-ink); }
  .an-card .ac-metric b { color: var(--violet-ink); }
  .an-card .ac-link { margin-top: auto; padding-top: 18px; font-family: var(--mono); font-size: 12px; color: var(--muted); }
  .an-card:hover .ac-link { color: var(--violet-ink); }

  .band { border-radius: 22px; }
  .band.dark { background: #0B0A12; }
  .tband { padding: clamp(28px,5vw,52px); }
  .tband .thead { max-width: 62ch; margin-bottom: 32px; }
  .tband h2 { font-size: clamp(24px, 3.4vw, 36px); }
  .tband .lead { margin-top: 14px; }
  .rstats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  @media (max-width: 720px) { .rstats { grid-template-columns: 1fr 1fr; } }
  .rstat { border: 1px solid var(--line); border-radius: 14px; padding: 20px; background: var(--ink-2); }
  .rstat .rn { font-family: var(--mono); font-size: 30px; font-weight: 700; color: var(--lime); letter-spacing: -0.03em; line-height: 1; }
  .rstat .rn small { font-size: 16px; color: var(--muted); }
  .rstat .rl { font-size: 13px; color: var(--muted); margin-top: 10px; line-height: 1.4; }
  .rcta { margin-top: 30px; display: flex; gap: 12px; flex-wrap: wrap; }
  .rsub { margin-top: 16px; font-family: var(--mono); font-size: 12.5px; color: #9A95B3; }
  .rsub a { color: var(--lime); text-decoration: none; }
  .rsub a:hover { text-decoration: underline; }
  .btn-ghost-light { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.25); }
  .btn-ghost-light:hover { border-color: var(--lime); }

  .final { text-align: center; overflow: hidden; }
  .final .fglow { position: absolute; inset: 0; z-index: 0; background: radial-gradient(600px 300px at 50% 40%, color-mix(in srgb, var(--violet) 26%, transparent), transparent 65%); pointer-events: none; }
  .final :global(.wrap) { position: relative; z-index: 1; }
  .final h2 { font-size: clamp(28px, 4.6vw, 46px); max-width: 20ch; margin-inline: auto; }
  .scanwrap { max-width: 640px; margin: 0 auto; text-align: left; }
</style>
