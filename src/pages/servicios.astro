---
import Base from '../layouts/Base.astro';
import Scanner from '../components/Scanner.astro';
import { siMeta, siWhatsapp, siGoogleads, siGmail, siGoogle, siPerplexity } from 'simple-icons';
import { getSeo } from '../lib/seo';
const seo = await getSeo('servicios', {
  title: 'Servicios — Optimiza',
  description: 'Velocidad, visibilidad, conversión y automatización: los cuatro pilares para que tu negocio venda más, explicados sin jerga y medidos en ventas.',
});
const title = seo.title;
const description = seo.description;
const check = 'M20 6 9 17l-5-5';
---
<Base
  title={title}
  description={description}
  active="servicios"
  ogImage={seo.ogImage}
  breadcrumbs={[{ name: 'Servicios', url: 'https://optimizahq.com/servicios/' }]}
>
  <section class="hero section dark">
    <div class="hero-glow"></div>
    <div class="wrap">
      <p class="eyebrow">Servicios</p>
      <h1>Cuatro palancas. Un objetivo: que tu negocio <span class="hl">venda</span>.</h1>
      <p class="lead">Velocidad, visibilidad, conversión y automatización trabajan juntas. No vendemos tareas técnicas sueltas — cada servicio existe para mover una métrica de negocio, y lo medimos en dinero.</p>
      <div class="pillnav">
        <a href="#velocidad" class="pn"><span class="pn-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"></path><path d="M3.34 19a10 10 0 1 1 17.32 0"></path></svg></span>Velocidad</a>
        <a href="#visibilidad" class="pn"><span class="pn-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg></span>Visibilidad</a>
        <a href="#conversion" class="pn"><span class="pn-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg></span>Conversión</a>
        <a href="#automatizacion" class="pn"><span class="pn-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="8" x="3" y="3" rx="2"></rect><path d="M7 11v4a2 2 0 0 0 2 2h4"></path><rect width="8" height="8" x="13" y="13" rx="2"></rect></svg></span>Automatización</a>
      </div>
    </div>
  </section>

  <section class="section" id="enfoque">
    <div class="wrap">
      <div class="lad-head reveal">
        <p class="eyebrow">Nuestro enfoque</p>
        <h2>Empezamos por tu web. Terminamos optimizando tu negocio.</h2>
        <p class="lead">La web es la puerta: lo medible, lo que todos entienden. Pero optimizar de verdad tu negocio depende de tu modelo y tu sector — por eso ningún plan es idéntico. La velocidad es igual para todos; lo demás lo diseñamos para ti.</p>
      </div>
      <div class="axis reveal">
        <div class="axis-step s1"><p class="as-name"><span class="ai"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"></path><path d="M3.34 19a10 10 0 1 1 17.32 0"></path></svg></span>Velocidad</p><p class="as-dep">Pura técnica · igual para todos</p></div>
        <div class="axis-step s2"><p class="as-name"><span class="ai"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg></span>Visibilidad</p><p class="as-dep">Dónde te buscan tus clientes</p></div>
        <div class="axis-step s3"><p class="as-name"><span class="ai"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg></span>Conversión</p><p class="as-dep">Cómo y qué vendes</p></div>
        <div class="axis-step s4"><p class="as-name"><span class="ai"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="8" x="3" y="3" rx="2"></rect><path d="M7 11v4a2 2 0 0 0 2 2h4"></path><rect width="8" height="8" x="13" y="13" rx="2"></rect></svg></span>Automatización</p><p class="as-dep">Tu operación y tu sector</p></div>
      </div>
      <div class="axis-scale reveal"><span>Universal · igual para todos</span><span class="ascale-bar"></span><span>Único · a la medida de tu negocio</span></div>
      <p class="axis-note reveal">Por eso no vendemos paquetes idénticos. Cada negocio es distinto — y así lo tratamos.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="pillar reveal" id="velocidad">
        <div class="txt">
          <div class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"></path><path d="M3.34 19a10 10 0 1 1 17.32 0"></path></svg></div>
          <p class="plabel">Pilar 01</p><h2>Velocidad</h2><p class="phook">"Cada segundo cuesta ventas."</p>
          <p class="pdesc">Tu cliente entra desde el celular, con datos y a veces mala señal. Si tu web tarda en abrir, se va con la competencia antes de ver tu producto. Cada segundo de carga te cuesta ventas reales — y Google castiga a los sitios lentos mostrándolos más abajo.</p>
          <ul class="plist glossed">
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Core Web Vitals</b><span>la nota que Google le pone a la experiencia de tu web; nota baja = apareces más abajo</span></div></li>
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Imágenes WebP / AVIF</b><span>fotos que pesan la mitad y se ven igual, para que la página vuele</span></div></li>
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Optimización de código</b><span>quitamos el peso muerto que hace lento tu sitio por dentro</span></div></li>
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Caché y CDN</b><span>tu web pre-armada y repartida por el mundo, lista para servirse al instante</span></div></li>
          </ul>
          <div class="presult">Resultado típico: <b>PageSpeed 38 → 96</b> · carga bajo 1s</div>
        </div>
        <div class="viz"><div class="panel">
          <div class="ptitle"><span>PageSpeed</span><span>antes → después</span></div>
          <div class="dualg">
            <div class="dg">
              <div class="dg-gauge">
                <svg viewBox="0 0 128 76" aria-hidden="true">
                  <path d="M12 68 A52 52 0 0 1 116 68" fill="none" stroke="rgba(130,130,150,0.16)" stroke-width="10" stroke-linecap="round"></path>
                  <path d="M12 68 A52 52 0 0 1 116 68" fill="none" stroke="#E24B4A" stroke-width="10" stroke-linecap="round" pathLength="100" stroke-dasharray="100" stroke-dashoffset="62"></path>
                </svg>
                <span class="dg-n bad">38</span>
              </div>
              <div class="dg-l">Antes</div>
            </div>
            <div class="dg-delta"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg><b>+58</b><span>pts</span></div>
            <div class="dg">
              <div class="dg-gauge">
                <svg viewBox="0 0 128 76" aria-hidden="true">
                  <path d="M12 68 A52 52 0 0 1 116 68" fill="none" stroke="rgba(130,130,150,0.16)" stroke-width="10" stroke-linecap="round"></path>
                  <path d="M12 68 A52 52 0 0 1 116 68" fill="none" stroke="#3FA23A" stroke-width="10" stroke-linecap="round" pathLength="100" stroke-dasharray="100" stroke-dashoffset="4"></path>
                </svg>
                <span class="dg-n good">96</span>
              </div>
              <div class="dg-l">Después</div>
            </div>
          </div>
          <div class="metric-row"><span class="mr-l">Carga móvil</span><span class="mr-v">6.1s <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg> <b>0.9s</b></span></div>
        </div></div>
      </div>

      <div class="pillar flip reveal" id="visibilidad">
        <div class="txt">
          <div class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg></div>
          <p class="plabel">Pilar 02</p><h2>Visibilidad</h2><p class="phook">"Que te encuentren primero."</p>
          <p class="pdesc">Cuando alguien busca lo que vendes —escribiéndolo en Google o preguntándole a ChatGPT— o apareces en los primeros lugares, o no existes para ese cliente. Si buscan "zapatos en Cartago" y no sales en la primera pantalla, la venta se la lleva otro. Te ponemos donde te encuentran.</p>
          <ul class="plist glossed">
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>SEO técnico y schema</b><span>que Google entienda y confíe en tu web para mostrarla arriba, con estrellitas, precio y datos</span></div></li>
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Contenido y clústeres</b><span>artículos que responden lo que tu cliente busca y te traen visitas gratis, mes a mes</span></div></li>
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Optimización para IA (GEO)</b><span>que ChatGPT y Perplexity te recomienden cuando un cliente les pregunta</span></div></li>
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Google Ads / PMax</b><span>anuncios que aparecen justo cuando alguien busca comprar, pagando por resultados</span></div></li>
          </ul>
          <div class="presult">Resultado típico: <b>top 3</b> en tus términos clave</div>
        </div>
        <div class="viz"><div class="panel">
          <div class="ptitle"><span class="pt-b"><svg class="pt-logo" viewBox="0 0 24 24"><path d={siGoogle.path} fill={`#${siGoogle.hex}`}></path></svg>Posición en Google</span><span>90 días</span></div>
          <div class="rankrow"><span class="rk-kw">"optimización web costa rica"</span><span class="rk-move"><b class="rkb">#9</b><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg><b class="rka">#1</b></span></div>
          <div class="rankrow"><span class="rk-kw">"mejorar velocidad web"</span><span class="rk-move"><b class="rkb">#14</b><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg><b class="rka">#3</b></span></div>
          <div class="rankrow"><span class="rk-kw">"agencia SEO pymes"</span><span class="rk-move"><b class="rkb">#22</b><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg><b class="rka">#4</b></span></div>
          <div class="rankrow ai"><span class="rk-kw">Visible en buscadores de IA</span><span class="ai-logos"><svg class="ail" viewBox="0 0 24 24"><path d={siPerplexity.path} fill={`#${siPerplexity.hex}`}></path></svg><svg class="ail" viewBox="0 0 24 24"><path d={siGoogle.path} fill={`#${siGoogle.hex}`}></path></svg><span class="ai-yes"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg></span></span></div>
        </div></div>
      </div>

      <div class="pillar reveal" id="conversion">
        <div class="txt">
          <div class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg></div>
          <p class="plabel">Pilar 03</p><h2>Conversión</h2><p class="phook">"Convierte tráfico en clientes."</p>
          <p class="pdesc">Ya inviertes en traer visitas — anuncios, tiempo, esfuerzo. Si de cada 100 solo te compra 1, el problema no es el tráfico, es lo que pasa cuando llegan. Hacemos que más terminen comprando o escribiéndote por WhatsApp, sin gastar un peso más en atraerlos.</p>
          <ul class="plist glossed">
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Landing pages</b><span>páginas con un solo objetivo: que compren o te escriban por WhatsApp, sin distracciones</span></div></li>
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Pruebas A/B</b><span>probamos dos versiones con clientes reales y nos quedamos con la que más vende</span></div></li>
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Medición GA4 / GTM</b><span>saber de dónde vienen tus ventas para invertir donde sí funciona, no a ciegas</span></div></li>
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Optimización de formularios</b><span>menos pasos y menos fricción para que no abandonen a mitad de camino</span></div></li>
          </ul>
          <div class="presult">Resultado típico: <b>+38%</b> de conversión</div>
        </div>
        <div class="viz"><div class="panel">
          <div class="ptitle"><span>Embudo de conversión</span><span>mismo tráfico</span></div>
          <div class="funnel">
            <div class="fstage"><div class="fbar v1" style="width:100%"><span class="fb-l">Visitas</span><span class="fb-n">10,000</span></div></div>
            <div class="fconv"><span class="fc-pct">7.2%</span><span class="fc-txt">de las visitas se vuelven lead</span></div>
            <div class="fstage"><div class="fbar v2" style="width:72%"><span class="fb-l">Leads</span><span class="fb-n">720</span></div></div>
            <div class="fconv"><span class="fc-pct">20.6%</span><span class="fc-txt">de los leads se vuelven venta</span></div>
            <div class="fstage"><div class="fbar v3" style="width:48%"><span class="fb-l">Ventas</span><span class="fb-n">148</span></div></div>
          </div>
          <div class="fdelta"><span class="fd-up"><svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M12 19V5M6 11l6-6 6 6" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"></path></svg>+38%</span> en ventas vs. el trimestre anterior</div>
        </div></div>
      </div>

      <div class="pillar flip reveal" id="automatizacion">
        <div class="txt">
          <div class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="8" x="3" y="3" rx="2"></rect><path d="M7 11v4a2 2 0 0 0 2 2h4"></path><rect width="8" height="8" x="13" y="13" rx="2"></rect></svg></div>
          <p class="plabel">Pilar 04</p><h2>Automatización</h2><p class="phook">"Que tu negocio trabaje sin ti."</p>
          <p class="pdesc">El crecimiento no debería costarte todas tus horas — ni vivir con tus clientes regados entre WhatsApp, Excel y correo. Conectamos todo en un solo sistema y automatizamos el seguimiento para devolverte tiempo y libertad.</p>
          <ul class="plist glossed">
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Montamos o integramos tu CRM</b><span>un solo lugar para todos tus clientes y conversaciones</span></div></li>
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Flujos de nurturing</b><span>mensajes de seguimiento automáticos para que ningún lead se enfríe</span></div></li>
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Reportes automáticos</b><span>tus números al día sin que tengas que armar nada</span></div></li>
            <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d={check} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg><div><b>Conexión de herramientas</b><span>que tu web, anuncios y CRM se hablen entre sí</span></div></li>
          </ul>
          <div class="presult">Resultado típico: <b>horas recuperadas</b> cada semana</div>
        </div>
        <div class="viz"><div class="panel">
          <div class="ptitle"><span>De canales dispersos → un sistema</span><span>24/7</span></div>
          <svg class="flowsvg" viewBox="0 0 460 306" role="img" aria-label="Leads de Meta Ads, Google Ads, WhatsApp, formulario web y SEO convergen en un CRM central y fluyen a seguimiento, nurturing y venta.">
            <defs><pattern id="fgrid" width="22" height="22" patternUnits="userSpaceOnUse"><path d="M22 0H0V22" fill="none" stroke="rgba(23,20,31,0.05)" stroke-width="1"></path></pattern></defs>
            <rect x="0" y="0" width="460" height="306" fill="url(#fgrid)"></rect>
            <g font-family="'Inter Variable', ui-sans-serif, system-ui, sans-serif" font-size="11.5">
              <g fill="#FFFFFF" stroke="rgba(23,20,31,0.13)">
                <rect x="6" y="24" width="134" height="32" rx="10"></rect><rect x="6" y="84" width="134" height="32" rx="10"></rect><rect x="6" y="144" width="134" height="32" rx="10"></rect><rect x="6" y="204" width="134" height="32" rx="10"></rect><rect x="6" y="264" width="134" height="32" rx="10"></rect>
              </g>
              <rect class="ct" x="12" y="27" width="26" height="26" rx="8" fill={`#${siMeta.hex}`}></rect><g transform="translate(18 33) scale(0.625)"><path d={siMeta.path} fill="#fff"></path></g><text x="47" y="44" fill="#17141F">Meta Ads</text>
              <rect class="ct" x="12" y="87" width="26" height="26" rx="8" fill={`#${siGoogleads.hex}`}></rect><g transform="translate(18 93) scale(0.625)"><path d={siGoogleads.path} fill="#fff"></path></g><text x="47" y="104" fill="#17141F">Google Ads</text>
              <rect class="ct" x="12" y="147" width="26" height="26" rx="8" fill={`#${siWhatsapp.hex}`}></rect><g transform="translate(18 153) scale(0.625)"><path d={siWhatsapp.path} fill="#fff"></path></g><text x="47" y="164" fill="#17141F">WhatsApp</text>
              <rect class="ct" x="12" y="207" width="26" height="26" rx="8" fill="#C65D3B"></rect><g transform="translate(18 213) scale(0.62)" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="18" rx="2"></rect><path d="M8 8h8M8 12h8M8 16h5"></path></g><text x="47" y="224" fill="#17141F">Formulario web</text>
              <rect class="ct" x="12" y="267" width="26" height="26" rx="8" fill="#1F9E52"></rect><g transform="translate(18 273) scale(0.62)" fill="none" stroke="#fff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4-4"></path></g><text x="47" y="284" fill="#17141F">SEO / orgánico</text>
              <g fill="none" stroke="#E8956B" stroke-opacity="0.5" stroke-width="1.8" stroke-linecap="round">
                <path class="flow" d="M140 40 C172 40 172 160 188 160" marker-end="url(#arwV)"></path>
                <path class="flow" d="M140 100 C174 100 170 160 188 160" marker-end="url(#arwV)"></path>
                <path class="flow" d="M140 160 L188 160" marker-end="url(#arwV)"></path>
                <path class="flow" d="M140 220 C174 220 170 160 188 160" marker-end="url(#arwV)"></path>
                <path class="flow" d="M140 280 C172 280 172 160 188 160" marker-end="url(#arwV)"></path>
              </g>
              <ellipse cx="248" cy="160" rx="72" ry="54" fill="url(#gVC)" opacity="0.13" style="filter: blur(11px)"></ellipse>
              <rect x="188" y="124" width="120" height="72" rx="16" fill="#FFFFFF" stroke="url(#gVC)" stroke-width="2" style="filter: drop-shadow(0 6px 15px rgba(198,93,59,0.16))"></rect>
              <g transform="translate(240 136) scale(0.62)" fill="none" stroke="#C65D3B" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5V19A9 3 0 0 0 21 19V5"></path><path d="M3 12A9 3 0 0 0 21 12"></path></g>
              <text x="248" y="170" text-anchor="middle" font-size="13" font-weight="700" fill="#A0522D">TU CRM</text>
              <text x="248" y="184" text-anchor="middle" font-size="10" fill="#615C74">un solo lugar</text>
              <g fill="none" stroke="#5FD9C1" stroke-opacity="0.6" stroke-width="1.8" stroke-linecap="round">
                <path class="flow" d="M308 160 C320 160 320 109 328 109" marker-end="url(#arwC)"></path>
                <path class="flow" d="M308 160 L328 167" marker-end="url(#arwC)"></path>
