---
const { active } = Astro.props;
const links = [
  { href: '/servicios', label: 'Servicios', key: 'servicios' },
  { href: '/nosotros', label: 'Nosotros', key: 'nosotros' },
  { href: '/analisis', label: 'Análisis', key: 'analisis' },
  { href: '/contacto', label: 'Contacto', key: 'contacto' },
];
---
<!-- Hallmark · nav: N5 floating pill · differs from N1a on: detachment, shape, positioning -->
<header class="nav" id="nav">
  <nav class="nav-pill" aria-label="Principal">
    <a class="brand" href="/" aria-label="Optimiza, inicio">
      <svg class="brandmark" viewBox="0 0 100 100" aria-hidden="true"><use href="#markB"></use></svg>
      Optimiza
    </a>
    <ul class="nav-links">
      {links.map((l) => (
        <li><a class:list={['link', { active: active === l.key }]} href={l.href}>{l.label}</a></li>
      ))}
    </ul>
    <a class="btn btn-violet cta-fill" href="/contacto">Diagnóstico gratis</a>
    <button class="nav-toggle" id="navToggle" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="navMobile">
      <span class="bars" aria-hidden="true"><i></i><i></i><i></i></span>
    </button>
  </nav>
  <div class="nav-scrim" id="navScrim"></div>
  <nav class="nav-mobile" id="navMobile" aria-label="Menú principal">
    {links.map((l) => (
      <a class:list={['m-link', { active: active === l.key }]} href={l.href}>{l.label}</a>
    ))}
    <a class="btn btn-violet m-cta" href="/contacto">Diagnóstico gratis</a>
  </nav>
</header>

<style>
  header.nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; pointer-events: none; }
  .nav-pill {
    pointer-events: auto;
    position: fixed; top: 18px; left: 50%; transform: translateX(-50%);
    display: inline-flex; align-items: center; gap: 22px;
    padding: 9px 10px 9px 20px;
    background: color-mix(in srgb, var(--surface) 82%, transparent);
    backdrop-filter: blur(14px) saturate(140%);
    border: 1px solid var(--line);
    border-radius: 999px;
    box-shadow: 0 12px 32px -16px rgba(20,15,10,0.28);
    transition: box-shadow .3s ease, background .3s ease;
    max-width: calc(100vw - 32px);
  }
  header.nav.scrolled .nav-pill { box-shadow: 0 16px 40px -14px rgba(20,15,10,0.36); }
  .brand { display: inline-flex; align-items: center; gap: 9px; font-weight: 700; letter-spacing: -0.03em; font-size: 16px; color: var(--text); white-space: nowrap; }
  .brandmark { width: 24px; height: 24px; display: block; }
  .nav-links { display: flex; align-items: center; gap: 18px; list-style: none; margin: 0; padding: 0; }
  .nav-links a.link { font-size: 14px; color: var(--muted); transition: color .16s ease; white-space: nowrap; }
  .nav-links a.link.active, .nav-links a.link:hover { color: var(--text); }
  .cta-fill { padding: 9px 16px; font-size: 13.5px; white-space: nowrap; }

  /* Botón hamburguesa (solo móvil) */
  .nav-toggle { display: none; width: 34px; height: 34px; align-items: center; justify-content: center; background: transparent; border: 0; cursor: pointer; color: var(--text); border-radius: 999px; flex: none; }
  .nav-toggle:hover { background: var(--line-soft); }
  .bars { position: relative; width: 18px; height: 13px; display: block; }
  .bars i { position: absolute; left: 0; right: 0; height: 2px; border-radius: 2px; background: currentColor; transition: transform .3s cubic-bezier(.2,.7,.2,1), opacity .2s, top .3s; }
  .bars i:nth-child(1) { top: 0; }
  .bars i:nth-child(2) { top: 5.5px; }
  .bars i:nth-child(3) { top: 11px; }
  .nav.menu-open .bars i:nth-child(1) { top: 5.5px; transform: rotate(45deg); }
  .nav.menu-open .bars i:nth-child(2) { opacity: 0; }
  .nav.menu-open .bars i:nth-child(3) { top: 5.5px; transform: rotate(-45deg); }

  /* Panel móvil + scrim */
  .nav-scrim { display: none; position: fixed; inset: 0; background: rgba(11,10,18,0.38); opacity: 0; pointer-events: none; transition: opacity .25s ease; z-index: 40; }
  .nav.menu-open .nav-scrim { opacity: 1; pointer-events: auto; }
  .nav-mobile { display: none; position: fixed; top: 76px; left: 16px; right: 16px; z-index: 45;
    flex-direction: column; gap: 2px; padding: 10px 20px 20px;
    background: var(--surface); border: 1px solid var(--line); border-radius: 20px;
    box-shadow: 0 24px 44px -20px rgba(20,15,10,0.4);
    transform: translateY(-10px); opacity: 0; pointer-events: none; visibility: hidden;
    transition: transform .3s cubic-bezier(.2,.7,.2,1), opacity .22s ease, visibility .3s; }
  .nav.menu-open .nav-mobile { transform: none; opacity: 1; pointer-events: auto; visibility: visible; }
  .m-link { font-size: 16px; color: var(--text); padding: 13px 4px; border-bottom: 1px solid var(--line-soft); }
  .m-link.active { color: var(--violet-ink); font-weight: 600; }
  .m-cta { margin-top: 14px; width: 100%; }

  @media (max-width: 780px) {
    .nav-links, .cta-fill { display: none; }
    .nav-toggle { display: inline-flex; }
    .nav-scrim, .nav-mobile { display: flex; }
    .nav-pill { top: 14px; padding: 7px 8px 7px 16px; gap: 12px; }
    .brandmark { width: 22px; height: 22px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .bars i, .nav-mobile, .nav-scrim { transition: none; }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  const toggle = document.getElementById('navToggle');
  const panel = document.getElementById('navMobile');
  const scrim = document.getElementById('navScrim');
  if (nav && toggle && panel && scrim) {
    const setOpen = (open: boolean) => {
      nav.classList.toggle('menu-open', open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
      if (open) panel.removeAttribute('inert');
      else panel.setAttribute('inert', '');
      document.body.style.overflow = open ? 'hidden' : '';
    };
    setOpen(false);
    toggle.addEventListener('click', () => setOpen(!nav.classList.contains('menu-open')));
    scrim.addEventListener('click', () => setOpen(false));
    panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && nav.classList.contains('menu-open')) { setOpen(false); toggle.focus(); }
    });
    window.addEventListener('resize', () => {
      if (window.innerWidth > 780 && nav.classList.contains('menu-open')) setOpen(false);
    });
  }
</script>
