---
import { siWhatsapp } from 'simple-icons';

// Número en formato internacional sin '+' ni espacios (ej: 50688887777).
const NUMBER = import.meta.env.PUBLIC_WHATSAPP_NUMBER;
const MSG = import.meta.env.PUBLIC_WHATSAPP_MSG || 'Hola Optimiza, quiero saber más sobre optimizar mi web.';
const href = NUMBER ? `https://wa.me/${NUMBER}?text=${encodeURIComponent(MSG)}` : null;
---
{href && (
  <a class="wa-fab" href={href} target="_blank" rel="noopener" aria-label="Escríbenos por WhatsApp">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d={siWhatsapp.path} /></svg>
    <span class="wa-txt">WhatsApp</span>
  </a>
)}

<style>
  .wa-fab {
    position: fixed; right: 22px; bottom: 22px; z-index: 60;
    display: inline-flex; align-items: center; gap: 0;
    height: 56px; padding: 0 16px; border-radius: 999px;
    background: #25D366; color: #fff;
    box-shadow: 0 10px 30px -8px rgba(37,211,102,0.6), 0 2px 8px rgba(0,0,0,0.15);
    overflow: hidden; max-width: 56px;
    transition: max-width .35s cubic-bezier(.2,.7,.2,1), box-shadow .2s, transform .15s;
  }
  .wa-fab svg { width: 26px; height: 26px; flex: none; fill: #fff; }
  .wa-txt {
    font-family: var(--sans); font-weight: 600; font-size: 15px; white-space: nowrap;
    max-width: 0; opacity: 0; margin-left: 0;
    transition: max-width .35s cubic-bezier(.2,.7,.2,1), opacity .25s, margin-left .35s;
  }
  .wa-fab:hover, .wa-fab:focus-visible { max-width: 220px; box-shadow: 0 14px 36px -8px rgba(37,211,102,0.7), 0 2px 8px rgba(0,0,0,0.18); }
  .wa-fab:hover .wa-txt, .wa-fab:focus-visible .wa-txt { max-width: 160px; opacity: 1; margin-left: 10px; }
  .wa-fab:active { transform: translateY(1px); }
  @media (max-width: 520px) { .wa-fab { right: 16px; bottom: 16px; } }
  @media (prefers-reduced-motion: reduce) { .wa-fab, .wa-txt { transition: none; } }
</style>
