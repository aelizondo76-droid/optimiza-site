---
import { siFacebook, siInstagram } from 'simple-icons';
// Redes activas hoy. LinkedIn/TikTok aún no tienen link confirmado — se agregan cuando existan.
const social = [
  { name: 'Facebook', href: 'https://www.facebook.com/people/Optimiza/61592304233725/', icon: siFacebook },
  { name: 'Instagram', href: 'https://www.instagram.com/optimizahq', icon: siInstagram },
];
---
<!-- Hallmark · footer: Ft5 statement · differs from Ft3 on: single closing line vs. sitemap columns -->
<footer class="ft dark">
  <div class="wrap">
    <p class="ft-line">Optimizamos tu negocio a través de tu web.<br/>Medido en ventas, no en reportes.</p>

    <div class="ft-meta">
      <a class="brand" href="/" aria-label="Optimiza">
        <svg class="brandmark" viewBox="0 0 100 100" aria-hidden="true"><use href="#markB"></use></svg>
        Optimiza
      </a>
      <nav class="ft-links" aria-label="Enlaces">
        <a href="/servicios/">Servicios</a>
        <a href="/nosotros/">Nosotros</a>
        <a href="/analisis/">Análisis</a>
        <a href="/contacto/">Contacto</a>
      </nav>
      <a class="ft-badge" href="/#scanner">Corre tu propio diagnóstico →</a>
      <div class="ft-social" aria-label="Redes sociales">
        {social.map((s) => (
          <a href={s.href} target="_blank" rel="noopener me" aria-label={s.name}>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d={s.icon.path}></path></svg>
          </a>
        ))}
      </div>
    </div>

    <div class="ft-bottom"><span>© 2026 Optimiza · optimizahq.com</span><span>Privacidad · Términos</span></div>
  </div>
</footer>

<style>
  footer.ft { border-top: 1px solid var(--line); }
  .ft-line { font-family: var(--display); font-weight: 700; font-size: clamp(28px, 4.2vw, 52px); line-height: 1.08; letter-spacing: -0.02em; max-width: 22ch; margin: 0 0 40px; color: var(--text); }
  .ft-meta { display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; padding-block-start: 22px; border-top: 1px solid var(--line-soft); }
  .brand { display: inline-flex; align-items: center; gap: 10px; font-weight: 700; letter-spacing: -0.03em; font-size: 17px; color: var(--text); }
  .brandmark { width: 24px; height: 24px; display: block; }
  .ft-links { display: flex; gap: 22px; flex-wrap: wrap; }
  .ft-links a { color: var(--muted); font-size: 14px; transition: color .15s; }
  .ft-links a:hover { color: var(--text); }
  .ft-badge { display: inline-flex; align-items: center; gap: 8px; border: 1px solid var(--line); border-radius: 10px; padding: 7px 12px; font-family: var(--mono); font-size: 11.5px; color: var(--muted); white-space: nowrap; transition: border-color .15s, color .15s; }
  .ft-badge:hover { border-color: var(--lime); color: var(--text); }
  .ft-social { display: inline-flex; align-items: center; gap: 10px; }
  .ft-social a { display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 999px; border: 1px solid var(--line); color: var(--muted); transition: color .15s, border-color .15s; }
  .ft-social a:hover { color: var(--text); border-color: var(--lime); }
  .ft-social svg { width: 15px; height: 15px; fill: currentColor; }
  .ft-bottom { border-top: 1px solid var(--line-soft); margin-top: 22px; padding-block: 20px 32px; display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; font-family: var(--mono); font-size: 11.5px; color: var(--faint); letter-spacing: 0.04em; }

  @media (max-width: 560px) {
    .ft-meta { flex-direction: column; align-items: flex-start; gap: 16px; }
    .ft-links { gap: 16px; }
  }
</style>
